# macOS
.DS_Store

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Xcode
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/

# 构建产物
*.dSYM/
*.app

# build-app.sh 的产物目录；保留 .gitkeep 作为目录占位
quota-bar/build/*
!quota-bar/build/.gitkeep

# web 子项目（双保险：web/.gitignore 也已排除，根 ignore 兜底）
web/node_modules/
web/dist/
web/.astro/
web/.output/
web/.vercel/

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# 临时文件
*.log
/tmp/

# Agent 工作的中间产物（保持 agent-log/ 干净）
.worktrees/
reference/project/hidden/
reference/project/Mos/
