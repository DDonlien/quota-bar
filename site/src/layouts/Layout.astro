---
import "../styles/global.css";
import { dictionaries } from "../i18n/dict";

const enDict = dictionaries.en;
const zhDict = dictionaries.zh;

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Quota Bar — AI 订阅额度，一眼可见",
  description = "macOS 菜单栏应用，自动探测并展示你的 AI 订阅额度。装上即用，无需配置，无需打开窗口。支持 Antigravity、Codex、Claude、MiniMax、Kimi、Zcode。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo-512-roundcorner.png" />
    <link rel="apple-touch-icon" href="/logo-512-roundcorner.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://quotabar.ddonlien.com" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- 主题色与 PWA -->
    <meta name="theme-color" content="#0f0f11" />
    <meta name="apple-mobile-web-app-title" content="Quota Bar" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <meta name="color-scheme" content="dark" />

    <!-- Preload 主字体（首屏可见）+ Regular weight（i18n 注入后开始渲染） -->
    <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/MapleMonoNL-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- 字体：JetBrains Mono（英文）+ Maple Mono NL（中文）自托管 woff2，
         在 global.css @font-face 声明，preload 主 weight 提升首屏体验 -->

    <!-- i18n 字典注入（同步内联） -->
    <script is:inline define:vars={{ enDict, zhDict }}>
      window.QB_I18N = { en: enDict, zh: zhDict };
    </script>

    <!-- 同步：检测 locale + 设 html lang/attribute（必须在 body 解析前） -->
    <script is:inline>
      (function () {
        var STORAGE = "qb_locale";
        function pick() {
          try {
            var s = localStorage.getItem(STORAGE);
            if (s === "en" || s === "zh") return s;
          } catch (e) {}
          var langs = [];
          try {
            if (navigator.languages && navigator.languages.length) {
              langs = navigator.languages;
            } else if (navigator.language) {
              langs = [navigator.language];
            }
          } catch (e) {}
          for (var i = 0; i < langs.length; i++) {
            var t = String(langs[i] || "").toLowerCase();
            if (t === "zh" || t.indexOf("zh-") === 0) return "zh";
          }
          return "en";
        }
        var locale = pick();
        var html = document.documentElement;
        html.lang = locale === "zh" ? "zh-CN" : "en";
        html.setAttribute("data-locale", locale);
        window.QB_LOCALE = locale;
      })();
    </script>

    <!-- 同步遍历 [data-i18n] 替换文本 + 处理属性（placeholder / aria-label / title） -->
    <script is:inline>
      (function () {
        var dict = window.QB_I18N || { en: {}, zh: {} };
        var cur = window.QB_LOCALE || "en";
        var firstApply = true;

        function resolve(key, locale) {
          return (dict[locale] && dict[locale][key]) || (dict.en && dict.en[key]) || null;
        }

        function apply(locale, isFirst) {
          var nodes = document.querySelectorAll("[data-i18n]");
          for (var i = 0; i < nodes.length; i++) {
            var el = nodes[i];
            var key = el.getAttribute("data-i18n");
            var val = resolve(key, locale);
            if (val != null) el.textContent = val;
            var ph = el.getAttribute("data-i18n-placeholder");
            if (ph) {
              var pval = resolve(ph, locale);
              if (pval != null) el.setAttribute("placeholder", pval);
            }
            var al = el.getAttribute("data-i18n-aria");
            if (al) {
              var aval = resolve(al, locale);
              if (aval != null) el.setAttribute("aria-label", aval);
            }
            var tit = el.getAttribute("data-i18n-title");
            if (tit) {
              var tval = resolve(tit, locale);
              if (tval != null) el.setAttribute("title", tval);
            }
          }

          if (!isFirst) {
            document.dispatchEvent(
              new CustomEvent("qb:locale-applied", { detail: { locale: locale } })
            );
          }
        }

        document.addEventListener("qb:locale-change", function (e) {
          var locale = (e.detail && e.detail.locale) || "en";
          cur = locale;
          document.documentElement.setAttribute("data-locale", locale);
          document.documentElement.lang = locale === "zh" ? "zh-CN" : "en";
          apply(locale, firstApply);
          firstApply = false;
        });

        window.QB_APPLY = function () {
          apply(cur, firstApply);
          firstApply = false;
        };
      })();
    </script>
  </head>
  <body>
    <!-- 全局装饰：顶部居中光晕（参考 reference.html） -->
    <div class="glow-effect"></div>

    <slot />

    <!-- 滚动入场动画：基于 IntersectionObserver，无依赖 -->
    <script>
      const reveals = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window && reveals.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
        );
        reveals.forEach((el) => observer.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add("is-visible"));
      }
    </script>

    <!-- i18n 增强：LocaleSwitcher 当前态 + 触发 apply -->
    <script is:inline>
      (function () {
        function refreshSwitcherTick(locale) {
          var ticks = document.querySelectorAll("[data-locale-pick] .locale-tick");
          ticks.forEach(function (t) {
            t.style.opacity =
              t.parentElement.getAttribute("data-locale-pick") === locale ? "1" : "0";
          });
          var lbls = document.querySelectorAll("[data-current-locale-label]");
          lbls.forEach(function (l) {
            l.textContent = locale === "zh" ? "中文" : "EN";
          });
        }

        if (typeof window.QB_APPLY === "function") window.QB_APPLY();
        refreshSwitcherTick(window.QB_LOCALE || "en");

        document.addEventListener("qb:locale-change", function (e) {
          var locale = (e.detail && e.detail.locale) || "en";
          refreshSwitcherTick(locale);
        });
      })();
    </script>
  </body>
</html>
