<script is:inline>
  (function () {
    // 进度条动画时长 + 读满后的视觉停留时长
    var PROGRESS_MS = 3500;  // CSS 动画时长（--tab-progress-duration）
    var HOLD_MS = 800;       // 进度条读满后多停留一会儿再切下一个
    var INTERVAL_MS = 4300;  // = PROGRESS_MS + HOLD_MS
    var tabsRoot = document.querySelector("[data-product-tabs]");
    var headingEl = document.querySelector("[data-product-heading]");
    if (!tabsRoot || !headingEl) return;

    var tabs = Array.prototype.slice.call(tabsRoot.querySelectorAll("[data-tab]"));
    if (!tabs.length) return;

    var imageMap = {};
    document.querySelectorAll("[data-tab-image]").forEach(function (el) {
      imageMap[el.getAttribute("data-tab-image")] = el;
    });

    var currentIdx = 0;
    var scheduledAt = null;        // 当前挂起的 setTimeout 句柄
    var lastTickAt = Date.now();   // 上次 tick 的真实墙钟时间，用于 visibility 补偿
    var dict = window.QB_I18N || { en: {}, zh: {} };
    function locale() {
      return (document.documentElement.getAttribute("data-locale") || "en");
    }
    function t(key) {
      var lc = locale();
      return (dict[lc] && dict[lc][key]) || (dict.en && dict.en[key]) || key;
    }

    function restartProgress(idx) {
      // 重置所有进度条：移除动画类 + 强制 reflow + 重新加
      tabs.forEach(function (tab, i) {
        var bar = tab.querySelector(".product-preview__tab-progress");
        if (!bar) return;
        if (i === idx) {
          bar.style.animation = "none";
          // 强制 reflow 触发重新计算
          void bar.offsetWidth;
          bar.style.animation = "";
        }
      });
    }

    function show(idx, fromUser) {
      if (idx === currentIdx) return;
      var next = ((idx % tabs.length) + tabs.length) % tabs.length;

      // fade out → swap text + active class + image → fade in
      headingEl.classList.add("is-fading");
      setTimeout(function () {
        tabs.forEach(function (el, i) {
          if (i === next) {
            el.classList.add("is-active");
            // 重新触发 fade-in 动画：先移除、再下一帧加回
            el.classList.remove("is-entering");
            // 强制 reflow 让浏览器重新计算动画
            void el.offsetWidth;
            el.classList.add("is-entering");
            // 动画结束后清理 class
            setTimeout(function () {
              el.classList.remove("is-entering");
            }, 320);
          } else {
            el.classList.remove("is-active");
            el.classList.remove("is-entering");
          }
        });
        var tabName = tabs[next].getAttribute("data-tab");
        headingEl.textContent = t("product.heading." + tabName);
        headingEl.classList.remove("is-fading");

        // 图片切换（aria-hidden 触发 360ms opacity fade）
        Object.keys(imageMap).forEach(function (k) {
          var el = imageMap[k];
          el.setAttribute("aria-hidden", k === tabName ? "false" : "true");
        });

        // 重启动画进度条
        restartProgress(next);

        currentIdx = next;
      }, 180);

      if (fromUser) restart();
    }

    function tick() {
      show(currentIdx + 1, false);
      // 重置参考时间戳：下次 scheduleNext 按「从这个 tick 开始」算 delay，
      // 否则 visibility 触发的 tick 会因为 lastTickAt 还是 start() 的时间，
      // 让 delay = max(0, INTERVAL_MS - huge_elapsed) = 0，导致连续 fire
      lastTickAt = Date.now();
      // 自调度：tick 完成后挂下一次 timer（之前 setInterval 自动续命，改 setTimeout 链要手动续）
      scheduleNext();
    }

    // —— 自调度定时器：用 Date.now() 记录真实墙钟时间，
    //   切到其它桌面/最小化浏览器后回来（setInterval 会被节流）能精准补偿。
    function start() {
      stop();
      lastTickAt = Date.now();
      scheduleNext();
    }
    function scheduleNext() {
      if (scheduledAt) {
        clearTimeout(scheduledAt);
        scheduledAt = null;
      }
      // 切到后台时不再调度（setTimeout 在 hidden tab 也可能被压到 1Hz，等回来时再补）
      if (document.hidden) return;
      var delay = Math.max(0, INTERVAL_MS - (Date.now() - lastTickAt));
      scheduledAt = setTimeout(function () {
        scheduledAt = null;
        tick();
      }, delay);
    }
    function stop() {
      if (scheduledAt) {
        clearTimeout(scheduledAt);
        scheduledAt = null;
      }
    }
    function restart() {
      start();
    }

    tabs.forEach(function (tab, i) {
      tab.addEventListener("click", function () {
        // 点击立即切 + 重置进度条动画 + 重启 timer
        show(i, true);
        // 用户主动点击：直接重置当前激活 tab 的进度条（让它重新走 3.5s）
        restartProgress(i);
      });
    });

    // 鼠标 hover 暂停自动播放 + 暂停进度条动画
    var section = tabsRoot.closest(".product-preview");
    if (section) {
      section.addEventListener("mouseenter", function () {
        stop();
        // 暂停所有进度条：把当前 animationPlayState 置 paused
        tabs.forEach(function (tab) {
          var bar = tab.querySelector(".product-preview__tab-progress");
          if (bar) bar.style.animationPlayState = "paused";
        });
      });
      section.addEventListener("mouseleave", function () {
        // 恢复进度条动画
        tabs.forEach(function (tab) {
          var bar = tab.querySelector(".product-preview__tab-progress");
          if (bar) bar.style.animationPlayState = "running";
        });
        start();
      });
    }

    // —— visibilitychange：从后台回到前台时精准 resync
    //   浏览器在 hidden tab 会把 setTimeout 节流到 ~1Hz，但 CSS animation 可能
    //   仍继续走 — 用户回来会看到「进度条满了但 tab 没切」。
    //   回来时：计算实际过了多久，过了 >= INTERVAL 就立刻 tick；并重置进度条动画，
    //   让用户看到一次干净的 0 → 100 播放。
    document.addEventListener("visibilitychange", function () {
      if (document.hidden) return;
      // 前台了：重置当前激活 tab 的进度条 + resync 定时器
      restartProgress(currentIdx);
      var elapsed = Date.now() - lastTickAt;
      if (elapsed >= INTERVAL_MS) {
        // 至少错过了 1 次 tick — 立即推进
        tick();
      } else {
        // 没到点，按剩余时间继续调度
        scheduleNext();
      }
    });

    // 监听 locale 切换，重新翻译当前 heading
    document.addEventListener("qb:locale-change", function () {
      var tabName = tabs[currentIdx].getAttribute("data-tab");
      headingEl.textContent = t("product.heading." + tabName);
    });

    // 初始启动
    start();
  })();
</script>
<script is:inline>
  /*
   * Adjust tab 拖拽动画时间轴（v1）
   *
   * 触发：data-tab-image="adjust" 的 aria-hidden 变为 false
   * 节奏（4.3s 一个循环，跟主 tab interval 对齐）：
   *   · 0.0s – 0.6s   静止，光标从右下角进入 panel
   *   · 0.6s – 0.8s   光标移到 Kimi 中心
   *   · 0.8s – 0.9s   grabbing：Kimi 抬起，Codex 让位
   *   · 0.9s – 1.2s   拖到 Codex 位置上方
   *   · 1.2s – 1.3s   落下，DOM reorder：Kimi / Codex / MiniMax
   *   · 1.3s – 3.0s   静止 1.7s
   *   · 3.0s – 3.2s   光标移到 MiniMax 的 Video 日额度
   *   · 3.2s – 3.3s   grabbing：Video 抬起，General 5h 让位
   *   · 3.3s – 3.6s   拖到 General 5h 位置上方
   *   · 3.6s – 3.7s   落下，DOM reorder
   *   · 3.7s – 4.3s   静止 0.6s
   *
   * 坐标系：
   *   .mockup--adjust (panel) — 整个演示窗
   *   .mockup__adjust   — 内部 panel，position: relative
   *     cursor + ghost  — 相对 .mockup__adjust 定位
   *     provider[.is-dragging] — 相对 .mockup__adjust-list 定位
   */
  (function () {
    var adjustImage = document.querySelector('[data-tab-image="adjust"]');
    var panel = document.querySelector('[data-adjust-panel]');
    if (!adjustImage || !panel) return;
    var inner = panel.querySelector('.mockup__adjust');
    var list = panel.querySelector('[data-adjust-list]');
    var ghost = panel.querySelector('[data-adjust-ghost]');
    var cursor = panel.querySelector('[data-adjust-cursor]');
    if (!inner || !list || !ghost || !cursor) return;

    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      // 跳过所有动画，直接隐藏光标
      cursor.setAttribute('data-hidden', 'true');
      return;
    }

    // ── DOM 引用 ──
    function byProvider(id) { return panel.querySelector('[data-provider="' + id + '"]'); }
    function byQuota(id) { return panel.querySelector('[data-quota="' + id + '"]'); }
    var codex = byProvider('codex');
    var kimi = byProvider('kimi');
    var minimax = byProvider('minimax');
    var quotasContainer = panel.querySelector('[data-adjust-quotas]');

    // ── 工具 ──
    function rect(el) { return el.getBoundingClientRect(); }
    function innerRect() { return rect(inner); }
    function listRect() { return rect(list); }
    function center(el) {
      var r = rect(el);
      var ir = innerRect();
      return {
        x: r.left - ir.left + r.width / 2,
        y: r.top - ir.top + r.height / 2
      };
    }
    function delay(ms) {
      return new Promise(function (resolve) { setTimeout(resolve, ms); });
    }
    function setCursor(x, y, ms) {
      cursor.style.transition = ms
        ? 'transform ' + ms + 'ms cubic-bezier(.4, 0, .2, 1)'
        : 'none';
      cursor.style.transform = 'translate3d(' + (x - 7) + 'px, ' + (y - 1) + 'px, 0)';
    }
    function setCursorState(state) {
      cursor.setAttribute('data-state', state || 'default');
    }
    function showGhost(card) {
      var r = rect(card);
      var ir = innerRect();
      ghost.style.left = (r.left - ir.left) + 'px';
      ghost.style.top = (r.top - ir.top) + 'px';
      ghost.style.width = r.width + 'px';
      ghost.style.height = r.height + 'px';
      ghost.classList.add('is-visible');
    }
    function hideGhost() { ghost.classList.remove('is-visible'); }
    function liftProvider(card) {
      // 视觉上锁定当前位置（避免 absolute 跳到 list 顶部）
      var r = rect(card);
      var lr = listRect();
      card.style.top = (r.top - lr.top) + 'px';
      card.style.left = '0';
      card.style.right = '0';
      card.style.width = 'auto';
      card.classList.add('is-dragging');
      // 立即生效，无过渡
      card.style.transition = 'none';
      card.style.transform = 'translate3d(0, 0, 0)';
      void card.offsetWidth;
      card.style.transition = '';
    }
    function liftQuota(card) {
      var r = rect(card);
      var qr = rect(quotasContainer);
      card.style.top = (r.top - qr.top) + 'px';
      card.style.left = '0';
      card.style.right = '0';
      card.style.width = 'auto';
      card.classList.add('is-dragging');
      card.style.transition = 'none';
      card.style.transform = 'translate3d(0, 0, 0)';
      void card.offsetWidth;
      card.style.transition = '';
    }
    function dragTo(card, dy, ms) {
      card.style.transition = 'transform ' + ms + 'ms cubic-bezier(.4, 0, .2, 1)';
      card.style.transform = 'translate3d(0, ' + dy + 'px, 0)';
    }
    function dropCard(card) {
      // 取消 dragging class，让其他卡片回到布局；card 自身 transform 归零
      card.classList.remove('is-dragging');
      card.style.transition = 'transform 80ms linear';
      card.style.transform = 'translate3d(0, 0, 0)';
      setTimeout(function () {
        card.style.transition = '';
        card.style.transform = '';
        card.style.top = '';
        card.style.left = '';
        card.style.right = '';
        card.style.width = '';
      }, 100);
    }
    function reorderProviders(ids) {
      var map = { codex: codex, kimi: kimi, minimax: minimax };
      var frag = document.createDocumentFragment();
      ids.forEach(function (id) { frag.appendChild(map[id]); });
      list.appendChild(frag);
    }
    function reorderQuotas(ids) {
      var map = {};
      quotasContainer.querySelectorAll('[data-quota]').forEach(function (el) {
        map[el.getAttribute('data-quota')] = el;
      });
      var frag = document.createDocumentFragment();
      ids.forEach(function (id) { frag.appendChild(map[id]); });
      quotasContainer.appendChild(frag);
    }

    // ── 时间轴 ──
    var playing = false;
    var cancelled = false;
    var currentRun = null;

    async function playTimeline() {
      if (playing) {
        cancelled = true;
        if (currentRun) currentRun.cancelled = true;
        await delay(50);  // 等旧 run 退出
        cancelled = false;
      }
      playing = true;
      var run = { cancelled: false };
      currentRun = run;

      // 重置到初始顺序
      reorderProviders(['codex', 'kimi', 'minimax']);
      reorderQuotas(['g5h', 'gweek', 'vday', 'vweek']);
      void panel.offsetWidth;  // 强制 reflow，让初始位置正确
      hideGhost();
      setCursorState('default');
      cursor.removeAttribute('data-hidden');

      try {
        // ── Phase 1: 进入（0 – 0.6s） ──
        // 光标从 panel 右下角进入
        var ir = innerRect();
        setCursor(ir.width * 0.88, ir.height * 0.96, 0);
        await delay(600);
        if (run.cancelled) return;

        // ── Phase 2: 移向 Kimi（0.6 – 0.8s） ──
        var kimiPos = center(kimi);
        setCursor(kimiPos.x, kimiPos.y, 200);
        await delay(200);
        if (run.cancelled) return;

        // ── Phase 3: 按住 + 抬起（0.8 – 0.9s） ──
        setCursorState('grabbing');
        showGhost(kimi);
        liftProvider(kimi);
        // 让 Codex 准备让位（添加 smooth class，让 transform 有过渡）
        codex.classList.add('is-smooth');
        await delay(80);
        if (run.cancelled) return;

        // ── Phase 4: 拖到 Codex 上方（0.9 – 1.2s） ──
        var codexPos = center(codex);
        var dyProvider = codexPos.y - kimiPos.y;  // 负值 = 上移
        setCursor(codexPos.x, codexPos.y, 320);
        dragTo(kimi, dyProvider, 320);
        await delay(320);
        if (run.cancelled) return;

        // ── Phase 5: 落下 + DOM reorder（1.2 – 1.3s） ──
        hideGhost();
        // 先把 Kimi 从 absolute 收回到 flow
        dropCard(kimi);
        // 等 50ms 再 reorder，避免浏览器抓不到当前几何
        setTimeout(function () {
          reorderProviders(['kimi', 'codex', 'minimax']);
          void panel.offsetWidth;
          // 移除 Codex 的 smooth class（避免影响后续）
          codex.classList.remove('is-smooth');
        }, 60);
        setCursorState('default');
        await delay(140);
        if (run.cancelled) return;

        // ── Phase 6: 静止 1.7s（1.3 – 3.0s） ──
        await delay(1700);
        if (run.cancelled) return;

        // ── Phase 7: 移向 MiniMax 的 Video 日额度（3.0 – 3.2s） ──
        var vday = byQuota('vday');
        var vdayPos = center(vday);
        setCursor(vdayPos.x, vdayPos.y, 200);
        await delay(200);
        if (run.cancelled) return;

        // ── Phase 8: 按住 + 抬起（3.2 – 3.3s） ──
        setCursorState('grabbing');
        showGhost(vday);
        liftQuota(vday);
        var g5h = byQuota('g5h');
        var g5hPos = center(g5h);
        var dyQuota = g5hPos.y - vdayPos.y;
        g5h.classList.add('is-smooth');
        await delay(60);
        if (run.cancelled) return;

        // ── Phase 9: 拖到 g5h 上方（3.3 – 3.6s） ──
        setCursor(g5hPos.x, g5hPos.y, 280);
        dragTo(vday, dyQuota, 280);
        await delay(280);
        if (run.cancelled) return;

        // ── Phase 10: 落下 + DOM reorder（3.6 – 3.7s） ──
        hideGhost();
        dropCard(vday);
        setTimeout(function () {
          reorderQuotas(['vday', 'g5h', 'gweek', 'vweek']);
          void panel.offsetWidth;
          g5h.classList.remove('is-smooth');
        }, 60);
        setCursorState('default');
        await delay(120);
        if (run.cancelled) return;

        // ── Phase 11: 静止 0.5s ──
        await delay(500);
      } finally {
        if (currentRun === run) {
          playing = false;
          currentRun = null;
        }
      }
    }

    // ── 接入 tab 系统：adjust tab 激活时跑时间轴 ──
    var pendingTimer = null;
    var observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        if (m.attributeName !== 'aria-hidden') return;
        var visible = adjustImage.getAttribute('aria-hidden') === 'false';
        if (!visible) return;
        // 取消旧的；300ms 后开始（让 tab fade-in 350ms 接上）
        if (pendingTimer) clearTimeout(pendingTimer);
        pendingTimer = setTimeout(function () {
          pendingTimer = null;
          playTimeline();
        }, 320);
      });
    });
    observer.observe(adjustImage, { attributes: true, attributeFilter: ['aria-hidden'] });

    // ── 鼠标 hover panel 时暂停；离开时恢复 ──
    var hoverPaused = false;
    panel.addEventListener('mouseenter', function () {
      hoverPaused = true;
      cursor.setAttribute('data-hidden', 'true');
      // 让所有过渡立即收尾（视觉上停在当前状态）
      [codex, kimi, minimax, byQuota('g5h'), byQuota('gweek'), byQuota('vday'), byQuota('vweek')].forEach(function (el) {
        if (el) {
          el.style.transition = 'none';
          // 强制 reflow 让 transform 生效
          void el.offsetWidth;
        }
      });
      cursor.style.transition = 'none';
    });
    panel.addEventListener('mouseleave', function () {
      hoverPaused = false;
      // 恢复 transitions
      [codex, kimi, minimax, byQuota('g5h'), byQuota('gweek'), byQuota('vday'), byQuota('vweek')].forEach(function (el) {
        if (el) el.style.transition = '';
      });
      cursor.style.transition = '';
      // 重新跑时间轴
      if (pendingTimer) clearTimeout(pendingTimer);
      pendingTimer = setTimeout(function () {
        pendingTimer = null;
        playTimeline();
      }, 200);
    });

    // ── visibilitychange：切回前台时如果 adjust 可见，重新跑 ──
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) return;
      if (adjustImage.getAttribute('aria-hidden') === 'false') {
        if (pendingTimer) clearTimeout(pendingTimer);
        pendingTimer = setTimeout(playTimeline, 200);
      }
    });
  })();
</script>
