---
// Product Preview — 16:9 大图（玻璃窗）+ 居中 tab + H2 标题
// 3 个 tab 可点击切换 + 自动循环播放；h2 内容跟着当前 active tab 切换
// 激活态视觉：
//   - 橙色背景 + 橙色边框（segmented control 里 active pill 风格）
//   - tab 内部左侧进度条 0%→100% 走 PROGRESS_MS 表达自动播放
//   - 图标 / 文字切到高亮色
// 上面 16:9 窗口里的图也跟着 active tab 切换（3 张 mockup，纯 CSS 占位）
// 节奏：vibeisland 1060 宽 / 12px 圆角窗口 / pill segmented tab
// 3 个 tab：monitor=总览（菜单栏查看）/ approve=详情（多模型多分层）/ adjust=调整（拖拽排序）
---

<!-- BEGIN: Product Preview Section -->
<section class="product-preview section">
  <div class="container-content">
    <div class="product-preview__window">
      <!-- 3 张占位 mockup：根据 active tab 切换可见性 + fade -->
      <div class="product-preview__image" data-tab-image="monitor" aria-hidden="false">
        <div class="mockup mockup--monitor">
          <div class="mockup__statusbar">
            <span class="mockup__pill mockup__pill--green"></span>
            <span class="mockup__line mockup__line--wide"></span>
            <span class="mockup__line mockup__line--narrow"></span>
          </div>
          <div class="mockup__grid">
            <div class="mockup__row mockup__row--3"><span></span><span></span><span></span></div>
            <div class="mockup__row mockup__row--2"><span></span><span></span></div>
            <div class="mockup__row mockup__row--2"><span></span><span></span></div>
            <div class="mockup__row mockup__row--1"></div>
          </div>
        </div>
      </div>

      <div class="product-preview__image" data-tab-image="approve" aria-hidden="true">
        <div class="mockup mockup--approve">
          <!-- 详情：多模型 × 多分层（5h / 周 / 月）的分组列表 -->
          <div class="mockup__detail">
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">5h</span>
            </div>
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">周</span>
            </div>
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">月</span>
            </div>
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">5h</span>
            </div>
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">周</span>
            </div>
          </div>
        </div>
      </div>

      <div class="product-preview__image" data-tab-image="adjust" aria-hidden="true">
        <!--
          Adjust: 1:1 还原 macOS app「菜单栏下拉面板」的 provider 排序交互。
          真实录屏参考：/Users/taobe/Movies/reorder.gif

          4.6s 循环内演示两段拖拽：
          · 0.0 – 0.7s   静止，Codex / Kimi / MiniMax 顺序
          · 0.7 – 1.3s   拖 Kimi 整块向上 → 落到 #1
          · 1.3 – 3.4s   静止，新顺序 Kimi / Codex / MiniMax
          · 3.4 – 3.8s   拖 MiniMax 内 Video 日额度向上 → 落到 #1
          · 3.8 – 4.3s   静止，结束

          DOM 设计：
          · 每个 .mockup__provider 是独立可拖块（normal flex child）
          · 拖拽中：.is-dragging → position: absolute + translate3d
          · 其他 provider 自然回流，让出空位
          · .mockup__ghost 是被拖块「原位」的虚线占位
          · .mockup__cursor 是模拟光标（独立 div，transform 动画）
        -->
        <div class="mockup mockup--adjust" data-adjust-panel>
          <div class="mockup__adjust">
            <header class="mockup__adjust-head">
              <div class="mockup__adjust-head-l">
                <div class="mockup__adjust-title">每月费用</div>
                <div class="mockup__adjust-sub">可用订阅</div>
              </div>
              <div class="mockup__adjust-head-r">
                <div class="mockup__adjust-amount">¥219/月</div>
                <div class="mockup__adjust-count">2/3</div>
              </div>
            </header>

            <div class="mockup__adjust-list" data-adjust-list>
              <!-- Codex Plus（provider #1，可拖） -->
              <article class="mockup__provider" data-provider="codex">
                <header class="mockup__provider-head">
                  <span class="mockup__provider-dot" aria-hidden="true"></span>
                  <span class="mockup__provider-name">Codex Plus</span>
                  <span class="mockup__provider-price">¥136/月</span>
                </header>
                <div class="mockup__quota">
                  <div class="mockup__quota-row">
                    <span class="mockup__quota-label">5 小时额度</span>
                    <span class="mockup__quota-meta">3h51m<span class="mockup__quota-pct">7%</span></span>
                  </div>
                  <div class="mockup__quota-bar"><div class="mockup__quota-fill" style="--w: 7%"></div></div>
                </div>
                <div class="mockup__quota">
                  <div class="mockup__quota-row">
                    <span class="mockup__quota-label">周额度</span>
                    <span class="mockup__quota-meta">6d9h<span class="mockup__quota-pct">69%</span></span>
                  </div>
                  <div class="mockup__quota-bar"><div class="mockup__quota-fill" style="--w: 69%"></div></div>
                </div>
              </article>

              <!-- Kimi Andante（provider #2，可拖） -->
              <article class="mockup__provider" data-provider="kimi">
                <header class="mockup__provider-head">
                  <span class="mockup__provider-dot" aria-hidden="true"></span>
                  <span class="mockup__provider-name">Kimi Andante</span>
                  <span class="mockup__provider-price">2026/7/10 ¥49/月</span>
                </header>
                <div class="mockup__quota">
                  <div class="mockup__quota-row">
                    <span class="mockup__quota-label">Code 5 小时额度</span>
                    <span class="mockup__quota-meta">5h0m<span class="mockup__quota-pct">100%</span></span>
                  </div>
                  <div class="mockup__quota-bar"><div class="mockup__quota-fill" style="--w: 100%"></div></div>
                </div>
                <div class="mockup__quota">
                  <div class="mockup__quota-row">
                    <span class="mockup__quota-label">Work 月额度</span>
                    <span class="mockup__quota-meta">9d7h<span class="mockup__quota-pct">0%</span></span>
                  </div>
                  <div class="mockup__quota-bar"><div class="mockup__quota-fill" style="--w: 0%"></div></div>
                </div>
              </article>

              <!-- MiniMax TokenPlan（provider #3，含 4 个子额度可拖） -->
              <article class="mockup__provider" data-provider="minimax">
                <header class="mockup__provider-head">
                  <span class="mockup__provider-dot mockup__provider-dot--green" aria-hidden="true"></span>
                  <span class="mockup__provider-name">MiniMax TokenPlan</span>
                  <span class="mockup__provider-price">¥34/月</span>
                </header>
                <div class="mockup__quotas" data-adjust-quotas>
                  <div class="mockup__quota" data-quota="g5h">
                    <div class="mockup__quota-row">
                      <span class="mockup__quota-label">General 5 小时额度</span>
                      <span class="mockup__quota-meta">4h15m<span class="mockup__quota-pct">71%</span></span>
                    </div>
                    <div class="mockup__quota-bar"><div class="mockup__quota-fill" style="--w: 71%"></div></div>
                  </div>
                  <div class="mockup__quota" data-quota="gweek">
                    <div class="mockup__quota-row">
                      <span class="mockup__quota-label">General 周额度</span>
                      <span class="mockup__quota-meta">4d23h<span class="mockup__quota-pct">77%</span></span>
                    </div>
                    <div class="mockup__quota-bar"><div class="mockup__quota-fill" style="--w: 77%"></div></div>
                  </div>
                  <div class="mockup__quota" data-quota="vday">
                    <div class="mockup__quota-row">
                      <span class="mockup__quota-label">Video 日额度</span>
                      <span class="mockup__quota-meta">23h15m<span class="mockup__quota-pct">100%</span></span>
                    </div>
                    <div class="mockup__quota-bar"><div class="mockup__quota-fill" style="--w: 100%"></div></div>
                  </div>
                  <div class="mockup__quota" data-quota="vweek">
                    <div class="mockup__quota-row">
                      <span class="mockup__quota-label">Video 周额度</span>
                      <span class="mockup__quota-meta">4d23h<span class="mockup__quota-pct">100%</span></span>
                    </div>
                    <div class="mockup__quota-bar"><div class="mockup__quota-fill" style="--w: 100%"></div></div>
                  </div>
                </div>
              </article>
            </div>

            <!-- 拖拽占位（被拖走的 provider 在原位置留下虚线框） -->
            <div class="mockup__ghost" data-adjust-ghost aria-hidden="true"></div>

            <!-- 模拟光标：DOM + transform 动画，跟随预设轨迹 -->
            <div class="mockup__cursor" data-adjust-cursor aria-hidden="true">
              <svg width="14" height="18" viewBox="0 0 14 18" fill="none">
                <path d="M1 1 L1 13 L4 10 L6.5 16 L8.5 15 L6 9 L10 9 Z" fill="white" stroke="rgba(0,0,0,0.85)" stroke-width="0.8" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="product-preview__tabs-row">
      <div class="product-preview__tabs" data-product-tabs>
        <button class="product-preview__tab is-active" type="button" data-tab="monitor">
          <span class="product-preview__tab-progress" aria-hidden="true"></span>
          <svg class="product-preview__tab-icon" fill="none" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="14" aria-hidden="true">
            <rect height="14" rx="2" ry="2" width="20" x="2" y="3"></rect>
            <line x1="8" x2="16" y1="21" y2="21"></line>
            <line x1="12" x2="12" y1="17" y2="21"></line>
          </svg>
          <span class="product-preview__tab-label" data-i18n="product.tab.monitor">Overview</span>
        </button>
        <button class="product-preview__tab" type="button" data-tab="approve">
          <span class="product-preview__tab-progress" aria-hidden="true"></span>
          <!-- 详情：横线三档（5h / 周 / 月）切换的视觉隐喻 -->
          <svg class="product-preview__tab-icon" fill="none" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="14" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18"></path>
          </svg>
          <span class="product-preview__tab-label" data-i18n="product.tab.approve">Details</span>
        </button>
        <button class="product-preview__tab" type="button" data-tab="adjust">
          <span class="product-preview__tab-progress" aria-hidden="true"></span>
          <!-- 调整：拖拽手柄 + 上下箭头 -->
          <svg class="product-preview__tab-icon" fill="none" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="14" aria-hidden="true">
            <circle cx="9" cy="6" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="9" cy="12" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="9" cy="18" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="15" cy="6" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="15" cy="12" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="15" cy="18" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
          <span class="product-preview__tab-label" data-i18n="product.tab.adjust">Adjust</span>
        </button>
      </div>
    </div>

    <h2 class="product-preview__heading" data-product-heading data-i18n="product.heading.monitor">
      All your quotas, at a glance.
    </h2>
  </div>
</section>
<!-- END: Product Preview Section -->

<style>
  /* ===== 16:9 窗口 + 3 张 mockup 占位图 ===== */
  .product-preview {
    /* 进度条动画时长（读满后还会停留 HOLD_MS 再切下一个 tab），
     * 必须跟 JS PROGRESS_MS 同步 */
    --tab-progress-duration: 3500ms;
  }

  .product-preview__window {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    background: var(--bg-elevated);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);  /* 12px */
    overflow: hidden;
  }

  .product-preview__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-7);  /* 32px 给 mockup 留呼吸 */
    opacity: 0;
    transition: opacity 360ms var(--ease-out);
    pointer-events: none;
  }
  .product-preview__image[aria-hidden="false"] {
    opacity: 1;
  }

  /* —— Mockup 占位骨架（深色 + 暖橙/绿高光；后续替换为真实截图） —— */
  .mockup {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .mockup__line {
    display: block;
    height: 8px;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.10);
  }
  .mockup__line--full { width: 100%; }
  .mockup__line--wide { width: 70%; }
  .mockup__line--medium { width: 50%; }
  .mockup__line--narrow { width: 30%; }
  .mockup__pill {
    display: inline-block;
    width: 36px;
    height: 18px;
    border-radius: 9px;
    background: rgba(255, 140, 0, 0.6);   /* 橙色 token — 与 tab 主题色一致 */
  }

  /* Monitor：状态栏 + 4 行进度条网格 */
  .mockup--monitor {
    background:
      linear-gradient(135deg, rgba(255, 140, 0, 0.06), transparent 60%),
      rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    gap: var(--space-5);
  }
  .mockup__statusbar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .mockup__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .mockup__row {
    display: grid;
    gap: var(--space-3);
  }
  .mockup__row > span {
    height: 24px;
    border-radius: var(--radius-sm);
    background: linear-gradient(
      90deg,
      rgba(255, 140, 0, 0.55) 0%,
      rgba(255, 140, 0, 0.55) var(--w, 60%),
      rgba(255, 255, 255, 0.08) var(--w, 60%),
      rgba(255, 255, 255, 0.08) 100%
    );
  }
  .mockup__row--1 { grid-template-columns: 1fr; }
  .mockup__row--2 { grid-template-columns: 1fr 1fr; }
  .mockup__row--3 { grid-template-columns: 1fr 1fr 1fr; }
  .mockup__row--1 > span { --w: 80%; }
  .mockup__row--2 > span:nth-child(1) { --w: 65%; }
  .mockup__row--2 > span:nth-child(2) { --w: 40%; }
  .mockup__row--3 > span:nth-child(1) { --w: 75%; }
  .mockup__row--3 > span:nth-child(2) { --w: 50%; }
  .mockup__row--3 > span:nth-child(3) { --w: 25%; }

  /* Approve（详情）：多模型 × 多分层的分组列表 */
  .mockup--approve {
    align-items: stretch;
    justify-content: center;
    background:
      radial-gradient(ellipse 60% 60% at 50% 50%, rgba(255, 140, 0, 0.04), transparent 70%);
    padding: var(--space-5);
  }
  .mockup__detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    background: rgba(20, 20, 24, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
  }
  .mockup__detail-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 6px 4px;
  }
  .mockup__chip {
    margin-left: auto;
    font-family: inherit;
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(255, 140, 0, 0.18);
    border: 1px solid rgba(255, 140, 0, 0.35);
    color: rgba(255, 140, 0, 0.95);
    font-weight: 500;
    flex-shrink: 0;
  }
  .mockup__avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255, 140, 0, 0.4);
    flex-shrink: 0;
  }

  /* Adjust（调整）：1:1 还原 macOS 菜单栏下拉面板 + 拖拽排序动画
   *
   * 结构：
   *   .mockup--adjust
   *     .mockup__adjust (面板本身)
   *       .mockup__adjust-head       — header (费用/订阅)
   *       .mockup__adjust-list       — provider flex 容器
   *         .mockup__provider ×3     — 每个 provider 卡片
   *           .mockup__provider-head — 名字 + 价格
   *           .mockup__quota ×N      — 子额度行（minimax 内可拖）
   *     .mockup__ghost               — 拖走后的虚线占位
   *     .mockup__cursor              — 模拟光标
   */
  .mockup--adjust {
    align-items: stretch;
    justify-content: stretch;
    padding: 24px 28px;
    position: relative;  /* ghost + cursor 相对此定位 */
    background:
      radial-gradient(ellipse 70% 60% at 50% 30%, rgba(255, 140, 0, 0.04), transparent 70%);
  }
  .mockup__adjust {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 14px 16px;
    background: rgba(20, 20, 24, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  /* —— Header：左标题 / 右价格 —— */
  .mockup__adjust-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .mockup__adjust-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }
  .mockup__adjust-sub {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-top: 2px;
  }
  .mockup__adjust-amount {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    text-align: right;
    line-height: 1.3;
  }
  .mockup__adjust-count {
    font-size: 11px;
    color: var(--text-tertiary);
    text-align: right;
    margin-top: 2px;
  }

  /* —— Provider 列表 —— */
  .mockup__adjust-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;  /* is-dragging 用 absolute 相对此定位 */
    flex: 1;
  }

  /* —— 单个 provider 卡片 —— */
  .mockup__provider {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px 10px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    transition:
      transform 280ms var(--ease-out),
      background 200ms var(--ease-out),
      border-color 200ms var(--ease-out),
      box-shadow 200ms var(--ease-out);
    will-change: transform;
  }
  .mockup__provider-head {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
  }
  .mockup__provider-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 140, 0, 0.85);
    flex-shrink: 0;
  }
  .mockup__provider-dot--green {
    background: rgba(74, 222, 128, 0.85);
  }
  .mockup__provider-name {
    font-weight: 600;
    color: var(--text-primary);
    flex: 0 1 auto;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mockup__provider-price {
    margin-left: auto;
    font-size: 11px;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* —— Quota 子项 —— */
  .mockup__quotas {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-top: 2px;
    position: relative;
  }
  .mockup__quota {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 2px 0;
    transition:
      transform 220ms var(--ease-out),
      background 200ms var(--ease-out);
    will-change: transform;
  }
  .mockup__quota-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    line-height: 1.2;
  }
  .mockup__quota-label {
    color: var(--text-secondary);
  }
  .mockup__quota-meta {
    color: var(--text-tertiary);
    font-variant-numeric: tabular-nums;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .mockup__quota-pct {
    color: var(--text-secondary);
    font-weight: 500;
  }
  .mockup__quota-bar {
    width: 100%;
    height: 3px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    overflow: hidden;
  }
  .mockup__quota-fill {
    width: var(--w, 0%);
    height: 100%;
    background: linear-gradient(
      90deg,
