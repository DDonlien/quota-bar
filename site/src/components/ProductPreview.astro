---
// Product Preview — 16:9 大图（玻璃窗）+ 居中 tab + H2 标题
// 3 个 tab 可点击切换 + 自动循环播放；h2 内容跟着当前 active tab 切换
// 激活态视觉：
//   - 橙色背景 + 橙色边框（segmented control 里 active pill 风格）
//   - tab 内部左侧进度条 0%→100% 走 PROGRESS_MS 表达自动播放
//   - 图标 / 文字切到高亮色
// 上面 16:9 窗口里的图也跟着 active tab 切换（3 张 mockup，纯 CSS 占位）
// 节奏：vibeisland 1060 宽 / 12px 圆角窗口 / pill segmented tab
// 3 个 tab：monitor=总览（菜单栏查看）/ approve=详情（多模型多分层）/ adjust=调整（拖拽排序）
---

<!-- BEGIN: Product Preview Section -->
<section class="product-preview section">
  <div class="container-content">
    <div class="product-preview__window">
      <!-- 3 张占位 mockup：根据 active tab 切换可见性 + fade -->
      <div class="product-preview__image" data-tab-image="monitor" aria-hidden="false">
        <div class="mockup mockup--monitor">
          <div class="mockup__statusbar">
            <span class="mockup__pill mockup__pill--green"></span>
            <span class="mockup__line mockup__line--wide"></span>
            <span class="mockup__line mockup__line--narrow"></span>
          </div>
          <div class="mockup__grid">
            <div class="mockup__row mockup__row--3"><span></span><span></span><span></span></div>
            <div class="mockup__row mockup__row--2"><span></span><span></span></div>
            <div class="mockup__row mockup__row--2"><span></span><span></span></div>
            <div class="mockup__row mockup__row--1"></div>
          </div>
        </div>
      </div>

      <div class="product-preview__image" data-tab-image="approve" aria-hidden="true">
        <div class="mockup mockup--approve">
          <!-- 详情：多模型 × 多分层（5h / 周 / 月）的分组列表 -->
          <div class="mockup__detail">
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">5h</span>
            </div>
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">周</span>
            </div>
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">月</span>
            </div>
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">5h</span>
            </div>
            <div class="mockup__detail-row">
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__chip">周</span>
            </div>
          </div>
        </div>
      </div>

      <div class="product-preview__image" data-tab-image="adjust" aria-hidden="true">
        <div class="mockup mockup--adjust">
          <!-- 调整：可拖拽排序的列表（带 6 点手柄） -->
          <div class="mockup__reorder">
            <div class="mockup__reorder-item mockup__reorder-item--active">
              <span class="mockup__grip" aria-hidden="true">
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
              </span>
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__bar"></span>
            </div>
            <div class="mockup__reorder-item">
              <span class="mockup__grip" aria-hidden="true">
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
              </span>
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__bar"></span>
            </div>
            <div class="mockup__reorder-item">
              <span class="mockup__grip" aria-hidden="true">
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
              </span>
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__bar"></span>
            </div>
            <div class="mockup__reorder-item">
              <span class="mockup__grip" aria-hidden="true">
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
              </span>
              <span class="mockup__avatar mockup__avatar--green"></span>
              <span class="mockup__line mockup__line--medium"></span>
              <span class="mockup__bar"></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="product-preview__tabs-row">
      <div class="product-preview__tabs" data-product-tabs>
        <button class="product-preview__tab is-active" type="button" data-tab="monitor">
          <span class="product-preview__tab-progress" aria-hidden="true"></span>
          <svg class="product-preview__tab-icon" fill="none" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="14" aria-hidden="true">
            <rect height="14" rx="2" ry="2" width="20" x="2" y="3"></rect>
            <line x1="8" x2="16" y1="21" y2="21"></line>
            <line x1="12" x2="12" y1="17" y2="21"></line>
          </svg>
          <span class="product-preview__tab-label" data-i18n="product.tab.monitor">Overview</span>
        </button>
        <button class="product-preview__tab" type="button" data-tab="approve">
          <span class="product-preview__tab-progress" aria-hidden="true"></span>
          <!-- 详情：横线三档（5h / 周 / 月）切换的视觉隐喻 -->
          <svg class="product-preview__tab-icon" fill="none" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="14" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18"></path>
          </svg>
          <span class="product-preview__tab-label" data-i18n="product.tab.approve">Details</span>
        </button>
        <button class="product-preview__tab" type="button" data-tab="adjust">
          <span class="product-preview__tab-progress" aria-hidden="true"></span>
          <!-- 调整：拖拽手柄 + 上下箭头 -->
          <svg class="product-preview__tab-icon" fill="none" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="14" aria-hidden="true">
            <circle cx="9" cy="6" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="9" cy="12" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="9" cy="18" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="15" cy="6" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="15" cy="12" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="15" cy="18" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
          <span class="product-preview__tab-label" data-i18n="product.tab.adjust">Adjust</span>
        </button>
      </div>
    </div>

    <h2 class="product-preview__heading" data-product-heading data-i18n="product.heading.monitor">
      All your quotas, at a glance.
    </h2>
  </div>
</section>
<!-- END: Product Preview Section -->

<style>
  /* ===== 16:9 窗口 + 3 张 mockup 占位图 ===== */
  .product-preview {
    /* 进度条动画时长（读满后还会停留 HOLD_MS 再切下一个 tab），
     * 必须跟 JS PROGRESS_MS 同步 */
    --tab-progress-duration: 3500ms;
  }

  .product-preview__window {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    background: var(--bg-elevated);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);  /* 12px */
    overflow: hidden;
  }

  .product-preview__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-7);  /* 32px 给 mockup 留呼吸 */
    opacity: 0;
    transition: opacity 360ms var(--ease-out);
    pointer-events: none;
  }
  .product-preview__image[aria-hidden="false"] {
    opacity: 1;
  }

  /* —— Mockup 占位骨架（深色 + 暖橙/绿高光；后续替换为真实截图） —— */
  .mockup {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .mockup__line {
    display: block;
    height: 8px;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.10);
  }
  .mockup__line--full { width: 100%; }
  .mockup__line--wide { width: 70%; }
  .mockup__line--medium { width: 50%; }
  .mockup__line--narrow { width: 30%; }
  .mockup__pill {
    display: inline-block;
    width: 36px;
    height: 18px;
    border-radius: 9px;
    background: rgba(255, 140, 0, 0.6);   /* 橙色 token — 与 tab 主题色一致 */
  }

  /* Monitor：状态栏 + 4 行进度条网格 */
  .mockup--monitor {
    background:
      linear-gradient(135deg, rgba(255, 140, 0, 0.06), transparent 60%),
      rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    gap: var(--space-5);
  }
  .mockup__statusbar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .mockup__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .mockup__row {
    display: grid;
    gap: var(--space-3);
  }
  .mockup__row > span {
    height: 24px;
    border-radius: var(--radius-sm);
    background: linear-gradient(
      90deg,
      rgba(255, 140, 0, 0.55) 0%,
      rgba(255, 140, 0, 0.55) var(--w, 60%),
      rgba(255, 255, 255, 0.08) var(--w, 60%),
      rgba(255, 255, 255, 0.08) 100%
    );
  }
  .mockup__row--1 { grid-template-columns: 1fr; }
  .mockup__row--2 { grid-template-columns: 1fr 1fr; }
  .mockup__row--3 { grid-template-columns: 1fr 1fr 1fr; }
  .mockup__row--1 > span { --w: 80%; }
  .mockup__row--2 > span:nth-child(1) { --w: 65%; }
  .mockup__row--2 > span:nth-child(2) { --w: 40%; }
  .mockup__row--3 > span:nth-child(1) { --w: 75%; }
  .mockup__row--3 > span:nth-child(2) { --w: 50%; }
  .mockup__row--3 > span:nth-child(3) { --w: 25%; }

  /* Approve（详情）：多模型 × 多分层的分组列表 */
  .mockup--approve {
    align-items: stretch;
    justify-content: center;
    background:
      radial-gradient(ellipse 60% 60% at 50% 50%, rgba(255, 140, 0, 0.04), transparent 70%);
    padding: var(--space-5);
  }
  .mockup__detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    background: rgba(20, 20, 24, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
  }
  .mockup__detail-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 6px 4px;
  }
  .mockup__chip {
    margin-left: auto;
    font-family: inherit;
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(255, 140, 0, 0.18);
    border: 1px solid rgba(255, 140, 0, 0.35);
    color: rgba(255, 140, 0, 0.95);
    font-weight: 500;
    flex-shrink: 0;
  }
  .mockup__avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255, 140, 0, 0.4);
    flex-shrink: 0;
  }

  /* Adjust（调整）：可拖拽排序的列表，每行有 6 点 grip 手柄 */
  .mockup--adjust {
    align-items: stretch;
    justify-content: center;
    background:
      linear-gradient(180deg, rgba(255, 140, 0, 0.04), transparent 80%);
    padding: var(--space-5);
  }
  .mockup__reorder {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    background: rgba(20, 20, 24, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
  }
  .mockup__reorder-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 8px 6px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.02);
    transition: background 220ms var(--ease-out);
  }
  .mockup__reorder-item--active {
    background: rgba(255, 140, 0, 0.12);
    border: 1px solid rgba(255, 140, 0, 0.35);
  }
  .mockup__grip {
    display: grid;
    grid-template-columns: repeat(2, 3px);
    gap: 2px;
    width: 8px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0.5;
  }
  .mockup__reorder-item--active .mockup__grip {
    opacity: 1;
  }
  .mockup__grip > span {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: currentColor;
  }
  .mockup__bar {
    width: 60px;
    height: 6px;
    margin-left: auto;
    border-radius: 3px;
    background: linear-gradient(
      90deg,
      rgba(255, 140, 0, 0.7) 0%,
      rgba(255, 140, 0, 0.7) 65%,
      rgba(255, 255, 255, 0.08) 65%,
      rgba(255, 255, 255, 0.08) 100%
    );
    flex-shrink: 0;
  }

  /* ===== Tab 行 ===== */
  .product-preview__tabs-row {
    display: flex;
    justify-content: center;
    margin-top: var(--space-7);  /* 32px */
    margin-bottom: var(--space-4);  /* 16px — 拉近 heading */
  }

  /* segmented control 外胶囊：深色玻璃 + 1px 浅边框 + 圆角 + 内 padding；
   * 3 个 tab 在胶囊里分布，未选中 tab 之间有 gap */
  .product-preview__tabs {
    display: inline-flex;
    align-items: stretch;
    gap: 4px;
    background: rgba(20, 20, 24, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-pill);
    padding: 4px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* —— Tab：未激活（idle，纯灰，无任何彩色） —— */
  .product-preview__tab {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--text-tertiary);   /* 纯灰文字 */
    font-size: var(--text-sm);  /* 13px */
    font-weight: 500;
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
    border: 1px solid transparent;  /* 透明边框预留 */
    user-select: none;
    isolation: isolate;
    white-space: nowrap;
  }

  /* —— Tab 文字不换行（即使外胶囊被压缩） —— */
  .product-preview__tab-label {
    white-space: nowrap;
  }

  /* —— Tab：hover（非激活态，浅橙主题色） —— */
  .product-preview__tab:hover:not(.is-active) {
    color: var(--text-primary);
    background: rgba(255, 140, 0, 0.10);       /* 极淡橙 */
    border-color: rgba(255, 140, 0, 0.30);     /* 淡橙边框 */
  }

  /* —— 进度条容器（默认 hidden，只在 active 态显示） —— */
  .product-preview__tab-progress {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: transparent;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }
  .product-preview__tab-progress::after {
    content: "";
    display: block;
    height: 100%;
    width: 100%;
    background: linear-gradient(
      90deg,
      rgba(255, 140, 0, 0.98) 0%,
      rgba(255, 140, 0, 0.85) 100%
    );
    border-radius: inherit;
    transform-origin: left center;
    transform: scaleX(0);
  }

  /* —— Tab：激活/读取中（橙色主题） —— */
  .product-preview__tab.is-active {
    color: #f9efe9;             /* 暖白文字，在橙色填充条上读着舒服 */
    border-color: rgba(255, 140, 0, 0.55);
    box-shadow: 0 0 0 1px rgba(255, 140, 0, 0.25);
  }
  .product-preview__tab.is-active .product-preview__tab-progress {
    opacity: 1;
    background: rgba(255, 140, 0, 0.18);  /* 浅橙底兜底 */
  }
  .product-preview__tab.is-active .product-preview__tab-progress::after {
    animation: tab-progress var(--tab-progress-duration, 3500ms)
      linear forwards;
  }

  /* —— icon / label：z-index 高于进度条 —— */
  .product-preview__tab-icon,
  .product-preview__tab-label {
    position: relative;
    z-index: 1;
    transition: color var(--duration-fast) var(--ease-out);
  }

  /* —— Tab 内容淡入：每次新激活 tab 时，icon + label 从 0.35 → 1，
   *    + translateY(3px → 0)，让切换看起来像「推进来」而不是「硬切」。 */
  .product-preview__tab.is-entering .product-preview__tab-icon,
  .product-preview__tab.is-entering .product-preview__tab-label {
    animation: tab-content-fade-in 280ms var(--ease-out);
  }
  @keyframes tab-content-fade-in {
    from { opacity: 0.35; transform: translateY(3px); }
    to   { opacity: 1;    transform: translateY(0); }
  }

  /* —— Tab：active + hover（加浓橙色主题，hover 暂停读取） —— */
  .product-preview__tab.is-active:hover {
    color: #fff;
    border-color: rgba(255, 140, 0, 0.85);
    box-shadow: 0 0 0 1px rgba(255, 140, 0, 0.45);
  }
  .product-preview__tab.is-active:hover .product-preview__tab-progress {
    background: rgba(255, 140, 0, 0.30);  /* 加深的橙底 */
  }

  @keyframes tab-progress {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  /* —— 标题 —— */
  .product-preview__heading {
    font-size: var(--text-2xl);  /* 24px desktop — section 修饰标题 */
    font-weight: 700;
    line-height: 1.3;
    text-align: center;
    letter-spacing: -0.005em;
    margin-top: 0;  /* 紧贴 tab 行 */
    color: var(--text-primary);
    transition: opacity var(--duration-base) var(--ease-out);
  }
  .product-preview__heading.is-fading {
    opacity: 0;
  }
  @media (max-width: 768px) {
    .product-preview__heading {
      font-size: var(--text-3xl);  /* 28px mobile — 略大补偿 */
    }
  }

  /* —— 减弱动效：跳过进度条动画 —— */
  @media (prefers-reduced-motion: reduce) {
    .product-preview__tab.is-active .product-preview__tab-progress::after {
      animation: none;
      transform: scaleX(1);
    }
    .product-preview__image {
      transition: none;
    }
    .product-preview__tab.is-entering .product-preview__tab-icon,
    .product-preview__tab.is-entering .product-preview__tab-label {
      animation: none;
    }
  }
</style>

<script is:inline>
  (function () {
    // 进度条动画时长 + 读满后的视觉停留时长
    var PROGRESS_MS = 3500;  // CSS 动画时长（--tab-progress-duration）
    var HOLD_MS = 800;       // 进度条读满后多停留一会儿再切下一个
    var INTERVAL_MS = 4300;  // = PROGRESS_MS + HOLD_MS
    var tabsRoot = document.querySelector("[data-product-tabs]");
    var headingEl = document.querySelector("[data-product-heading]");
    if (!tabsRoot || !headingEl) return;

    var tabs = Array.prototype.slice.call(tabsRoot.querySelectorAll("[data-tab]"));
    if (!tabs.length) return;

    var imageMap = {};
    document.querySelectorAll("[data-tab-image]").forEach(function (el) {
      imageMap[el.getAttribute("data-tab-image")] = el;
    });

    var currentIdx = 0;
    var scheduledAt = null;        // 当前挂起的 setTimeout 句柄
    var lastTickAt = Date.now();   // 上次 tick 的真实墙钟时间，用于 visibility 补偿
    var dict = window.QB_I18N || { en: {}, zh: {} };
    function locale() {
      return (document.documentElement.getAttribute("data-locale") || "en");
    }
    function t(key) {
      var lc = locale();
      return (dict[lc] && dict[lc][key]) || (dict.en && dict.en[key]) || key;
    }

    function restartProgress(idx) {
      // 重置所有进度条：移除动画类 + 强制 reflow + 重新加
      tabs.forEach(function (tab, i) {
        var bar = tab.querySelector(".product-preview__tab-progress");
        if (!bar) return;
        if (i === idx) {
          bar.style.animation = "none";
          // 强制 reflow 触发重新计算
          void bar.offsetWidth;
          bar.style.animation = "";
        }
      });
    }

    function show(idx, fromUser) {
      if (idx === currentIdx) return;
      var next = ((idx % tabs.length) + tabs.length) % tabs.length;

      // fade out → swap text + active class + image → fade in
      headingEl.classList.add("is-fading");
      setTimeout(function () {
        tabs.forEach(function (el, i) {
          if (i === next) {
            el.classList.add("is-active");
            // 重新触发 fade-in 动画：先移除、再下一帧加回
            el.classList.remove("is-entering");
            // 强制 reflow 让浏览器重新计算动画
            void el.offsetWidth;
            el.classList.add("is-entering");
            // 动画结束后清理 class
            setTimeout(function () {
              el.classList.remove("is-entering");
            }, 320);
          } else {
            el.classList.remove("is-active");
            el.classList.remove("is-entering");
          }
        });
        var tabName = tabs[next].getAttribute("data-tab");
        headingEl.textContent = t("product.heading." + tabName);
        headingEl.classList.remove("is-fading");

        // 图片切换（aria-hidden 触发 360ms opacity fade）
        Object.keys(imageMap).forEach(function (k) {
          var el = imageMap[k];
          el.setAttribute("aria-hidden", k === tabName ? "false" : "true");
        });

        // 重启动画进度条
        restartProgress(next);

        currentIdx = next;
      }, 180);

      if (fromUser) restart();
    }

    function tick() {
      show(currentIdx + 1, false);
      // 重置参考时间戳：下次 scheduleNext 按「从这个 tick 开始」算 delay，
      // 否则 visibility 触发的 tick 会因为 lastTickAt 还是 start() 的时间，
      // 让 delay = max(0, INTERVAL_MS - huge_elapsed) = 0，导致连续 fire
      lastTickAt = Date.now();
      // 自调度：tick 完成后挂下一次 timer（之前 setInterval 自动续命，改 setTimeout 链要手动续）
      scheduleNext();
    }

    // —— 自调度定时器：用 Date.now() 记录真实墙钟时间，
    //   切到其它桌面/最小化浏览器后回来（setInterval 会被节流）能精准补偿。
    function start() {
      stop();
      lastTickAt = Date.now();
      scheduleNext();
    }
    function scheduleNext() {
      if (scheduledAt) {
        clearTimeout(scheduledAt);
        scheduledAt = null;
      }
      // 切到后台时不再调度（setTimeout 在 hidden tab 也可能被压到 1Hz，等回来时再补）
      if (document.hidden) return;
      var delay = Math.max(0, INTERVAL_MS - (Date.now() - lastTickAt));
      scheduledAt = setTimeout(function () {
        scheduledAt = null;
        tick();
      }, delay);
    }
    function stop() {
      if (scheduledAt) {
        clearTimeout(scheduledAt);
        scheduledAt = null;
      }
    }
    function restart() {
      start();
    }

    tabs.forEach(function (tab, i) {
      tab.addEventListener("click", function () {
        // 点击立即切 + 重置进度条动画 + 重启 timer
        show(i, true);
        // 用户主动点击：直接重置当前激活 tab 的进度条（让它重新走 3.5s）
        restartProgress(i);
      });
    });

    // 鼠标 hover 暂停自动播放 + 暂停进度条动画
    var section = tabsRoot.closest(".product-preview");
    if (section) {
      section.addEventListener("mouseenter", function () {
        stop();
        // 暂停所有进度条：把当前 animationPlayState 置 paused
        tabs.forEach(function (tab) {
          var bar = tab.querySelector(".product-preview__tab-progress");
          if (bar) bar.style.animationPlayState = "paused";
        });
      });
      section.addEventListener("mouseleave", function () {
        // 恢复进度条动画
        tabs.forEach(function (tab) {
          var bar = tab.querySelector(".product-preview__tab-progress");
          if (bar) bar.style.animationPlayState = "running";
        });
        start();
      });
    }

    // —— visibilitychange：从后台回到前台时精准 resync
    //   浏览器在 hidden tab 会把 setTimeout 节流到 ~1Hz，但 CSS animation 可能
    //   仍继续走 — 用户回来会看到「进度条满了但 tab 没切」。
    //   回来时：计算实际过了多久，过了 >= INTERVAL 就立刻 tick；并重置进度条动画，
    //   让用户看到一次干净的 0 → 100 播放。
    document.addEventListener("visibilitychange", function () {
      if (document.hidden) return;
      // 前台了：重置当前激活 tab 的进度条 + resync 定时器
      restartProgress(currentIdx);
      var elapsed = Date.now() - lastTickAt;
      if (elapsed >= INTERVAL_MS) {
        // 至少错过了 1 次 tick — 立即推进
        tick();
      } else {
        // 没到点，按剩余时间继续调度
        scheduleNext();
      }
    });

    // 监听 locale 切换，重新翻译当前 heading
    document.addEventListener("qb:locale-change", function () {
      var tabName = tabs[currentIdx].getAttribute("data-tab");
      headingEl.textContent = t("product.heading." + tabName);
    });

    // 初始启动
    start();
  })();
</script>