---
// Product Preview — 16:9 大图（玻璃窗）+ 居中 tab + H2 标题
// 节奏：vibeisland 1060 宽 / 12px 圆角窗口 / 8px 圆角 segmented tab
---

<!-- BEGIN: Product Preview Section -->
<section class="product-preview section">
  <div class="container-content">
    <div class="product-preview__window">
      <img
        alt="Quota Bar Interface Preview"
        class="product-preview__image"
        src="https://lh3.googleusercontent.com/aida/AP1WRLuvOC6LQmX85RdTgKI9xG6B5-NrIrfSR2PcBbOBXcTlAiBrurHCdGWbM0pn7a2jJ5Veq0WNqkRNigvZC99m_u0UtEq_EbMVG50IK4K5fyEZJbUymh1gXLNjzfx6iI2otO7w-aQJtUMMXLvUrjpb6AgHz-XqN8gM6QJiP5nqYqWzqulcFc8CciCwjvNODIpEyGHvkUNmKW-x6VPvG8SyWX14GLbnqcRi8LnYWsGQUaFFuzyJJrX-OSW_TDOl"
      />
    </div>

    <div class="product-preview__tabs-row">
      <div class="product-preview__tabs">
        <button class="product-preview__tab product-preview__tab--active" type="button">
          <svg
            fill="none"
            height="14"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="14"
          >
            <rect height="14" rx="2" ry="2" width="20" x="2" y="3"></rect>
            <line x1="8" x2="16" y1="21" y2="21"></line>
            <line x1="12" x2="12" y1="17" y2="21"></line>
          </svg>
          <span data-i18n="product.tab.monitor">Monitor</span>
        </button>
        <button class="product-preview__tab" type="button">
          <svg
            fill="none"
            height="14"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="14"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
          <span data-i18n="product.tab.approve">Approve</span>
        </button>
        <button class="product-preview__tab" type="button">
          <svg
            fill="none"
            height="14"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="14"
          >
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
          <span data-i18n="product.tab.ask">Ask</span>
        </button>
        <button class="product-preview__tab" type="button">
          <svg
            fill="none"
            height="14"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="14"
          >
            <line x1="5" x2="19" y1="12" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
          <span data-i18n="product.tab.jump">Jump</span>
        </button>
      </div>
    </div>

    <h2 class="product-preview__heading">
      <span data-i18n="product.heading">All your quotas, at a glance.</span>
    </h2>
  </div>
</section>
<!-- END: Product Preview Section -->

<style>
  .product-preview__window {
    aspect-ratio: 16 / 9;
    width: 100%;
    background: var(--bg-elevated);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);  /* 12px */
    overflow: hidden;
  }

  .product-preview__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.92;
  }

  .product-preview__tabs-row {
    display: flex;
    justify-content: center;
    margin-top: var(--space-7);  /* 32px */
    margin-bottom: var(--space-5);  /* 20px */
  }

  /* segmented control 风格（vibeisland）：单一玻璃底 + 内部 active 切色 */
  .product-preview__tabs {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-pill);
    padding: 4px;
  }

  .product-preview__tab {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px 16px;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--text-tertiary);
    font-size: var(--text-sm);  /* 13px */
    font-weight: 500;
    transition:
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  .product-preview__tab:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
  }
  .product-preview__tab--active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.1);
  }

  .product-preview__heading {
    font-size: var(--text-3xl);  /* 36px desktop */
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    letter-spacing: -0.01em;
    margin-top: var(--space-7);  /* 32px */
    color: var(--text-primary);
  }
  @media (max-width: 768px) {
    .product-preview__heading {
      font-size: var(--text-2xl);  /* 28px mobile */
    }
  }
</style>