---
// Product Preview — 16:9 大图（玻璃窗）+ 居中 tab + H2 标题
// 4 个 tab 可点击切换 + 自动循环播放；h2 内容跟着当前 active tab 切换
// 节奏：vibeisland 1060 宽 / 12px 圆角窗口 / pill segmented tab
---

<!-- BEGIN: Product Preview Section -->
<section class="product-preview section">
  <div class="container-content">
    <div class="product-preview__window">
      <img
        alt="Quota Bar Interface Preview"
        class="product-preview__image"
        src="https://lh3.googleusercontent.com/aida/AP1WRLuvOC6LQmX85RdTgKI9xG6B5-NrIrfSR2PcBbOBXcTlAiBrurHCdGWbM0pn7a2jJ5Veq0WNqkRNigvZC99m_u0UtEq_EbMVG50IK4K5fyEZJbUymh1gXLNjzfx6iI2otO7w-aQJtUMMXLvUrjpb6AgHz-XqN8gM6QJiP5nqYqWzqulcFc8CciCwjvNODIpEyGHvkUNmKW-x6VPvG8SyWX14GLbnqcRi8LnYWsGQUaFFuzyJJrX-OSW_TDOl"
      />
    </div>

    <div class="product-preview__tabs-row">
      <div class="product-preview__tabs" data-product-tabs>
        <button class="product-preview__tab is-active" type="button" data-tab="monitor" data-i18n="product.tab.monitor">Monitor</button>
        <button class="product-preview__tab" type="button" data-tab="approve" data-i18n="product.tab.approve">Approve</button>
        <button class="product-preview__tab" type="button" data-tab="ask" data-i18n="product.tab.ask">Ask</button>
        <button class="product-preview__tab" type="button" data-tab="jump" data-i18n="product.tab.jump">Jump</button>
      </div>
    </div>

    <h2 class="product-preview__heading" data-product-heading data-i18n="product.heading.monitor">
      All your quotas, at a glance.
    </h2>
  </div>
</section>
<!-- END: Product Preview Section -->

<style>
  .product-preview__window {
    aspect-ratio: 16 / 9;
    width: 100%;
    background: var(--bg-elevated);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);  /* 12px */
    overflow: hidden;
  }

  .product-preview__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.92;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  .product-preview__tabs-row {
    display: flex;
    justify-content: center;
    margin-top: var(--space-7);  /* 32px */
    margin-bottom: var(--space-4);  /* 16px — 拉近 heading */
  }

  /* segmented control 风格（vibeisland）：单一玻璃底 + 内部 active 切色 */
  .product-preview__tabs {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-pill);
    padding: 4px;
  }

  .product-preview__tab {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px 16px;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--text-tertiary);
    font-size: var(--text-sm);  /* 13px */
    font-weight: 500;
    transition:
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }
  .product-preview__tab:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
  }
  .product-preview__tab.is-active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.1);
  }

  .product-preview__heading {
    font-size: var(--text-2xl);  /* 24px desktop — section 修饰标题 */
    font-weight: 700;
    line-height: 1.3;
    text-align: center;
    letter-spacing: -0.005em;
    margin-top: 0;  /* 紧贴 tab 行 */
    color: var(--text-primary);
    transition: opacity var(--duration-base) var(--ease-out);
  }
  .product-preview__heading.is-fading {
    opacity: 0;
  }
  @media (max-width: 768px) {
    .product-preview__heading {
      font-size: var(--text-3xl);  /* 28px mobile — 略大补偿 */
    }
  }
</style>

<script is:inline>
  (function () {
    var INTERVAL_MS = 3500;  // 自动播放间隔
    var tabsRoot = document.querySelector("[data-product-tabs]");
    var headingEl = document.querySelector("[data-product-heading]");
    if (!tabsRoot || !headingEl) return;

    var tabs = Array.prototype.slice.call(tabsRoot.querySelectorAll("[data-tab]"));
    if (!tabs.length) return;

    var currentIdx = 0;
    var timer = null;
    var dict = window.QB_I18N || { en: {}, zh: {} };
    function locale() {
      return (document.documentElement.getAttribute("data-locale") || "en");
    }
    function t(key) {
      var lc = locale();
      return (dict[lc] && dict[lc][key]) || (dict.en && dict.en[key]) || key;
    }

    function show(idx, fromUser) {
      if (idx === currentIdx) return;
      var next = ((idx % tabs.length) + tabs.length) % tabs.length;

      // fade out → swap text + active class → fade in
      headingEl.classList.add("is-fading");
      setTimeout(function () {
        tabs.forEach(function (el, i) {
          if (i === next) el.classList.add("is-active");
          else el.classList.remove("is-active");
        });
        var tabName = tabs[next].getAttribute("data-tab");
        headingEl.textContent = t("product.heading." + tabName);
        headingEl.classList.remove("is-fading");
        currentIdx = next;
      }, 180);

      if (fromUser) restart();
    }

    function tick() {
      show(currentIdx + 1, false);
    }

    function start() {
      stop();
      timer = setInterval(tick, INTERVAL_MS);
    }
    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }
    function restart() {
      start();
    }

    tabs.forEach(function (tab, i) {
      tab.addEventListener("click", function () {
        show(i, true);
      });
    });

    // 鼠标 hover 暂停自动播放
    var section = tabsRoot.closest(".product-preview");
    if (section) {
      section.addEventListener("mouseenter", stop);
      section.addEventListener("mouseleave", start);
    }

    // 监听 locale 切换，重新翻译当前 heading
    document.addEventListener("qb:locale-change", function () {
      var tabName = tabs[currentIdx].getAttribute("data-tab");
      headingEl.textContent = t("product.heading." + tabName);
    });

    // 初始启动
    start();
  })();
</script>