---
/**
 * MenuBarMockup.astro
 *
 * Quota Bar 主页的核心视觉资产 —— 纯 CSS/HTML 像素级还原 macOS 26 菜单栏 + dropdown。
 * 不依赖任何截图，循环动画展示 progress bar 的"一眼看到额度"卖点。
 *
 * 数据基于 QuotaModels.swift 的真实结构：
 *   provider + subscriptionGroup + quota window（title + periodLabel + fraction）
 *
 * 两种尺寸：
 *   variant="hero"       —— 紧凑版，用于 Hero 右侧（菜单栏横条 + dropdown 浮层组合）
 *   variant="standalone" —— 纯 dropdown 放大版，用于 Showcase 区
 */

export interface Props {
  variant?: "hero" | "standalone";
}

const { variant = "hero" } = Astro.props;

// —— 模拟数据：基于真实 provider 额度结构（stableKey 风格）——
// fraction 对应 statusColor 逻辑：>0.3 绿 / ≤0.3 橙 / =0 红
const providers = [
  {
    name: "Codex",
    color: "var(--provider-codex)",
    tier: "Pro",
    quotas: [
      { label: "5 小时额度", fraction: 0.72 },
      { label: "周额度", fraction: 0.58 },
    ],
  },
  {
    name: "Antigravity",
    color: "var(--provider-antigravity)",
    tier: "Pro",
    quotas: [
      { label: "Gemini 月额度", fraction: 0.85 },
      { label: "Other 月额度", fraction: 0.41 },
    ],
  },
  {
    name: "Claude",
    color: "var(--provider-claude)",
    tier: "Pro",
    quotas: [{ label: "周额度", fraction: 0.23 }],
  },
  {
    name: "MiniMax",
    color: "var(--provider-minimax)",
    tier: "Pro",
    quotas: [
      { label: "General 月额度", fraction: 0.66 },
      { label: "Video 月额度", fraction: 0 },
    ],
  },
  {
    name: "Kimi",
    color: "var(--provider-kimi)",
    tier: "Allegretto",
    quotas: [
      { label: "Code 5 小时额度", fraction: 0.91 },
      { label: "Work 月额度", fraction: 0.47 },
    ],
  },
  {
    name: "Zcode",
    color: "var(--provider-zcode)",
    tier: "Pro",
    quotas: [{ label: "月额度", fraction: 0.55 }],
  },
];

// 根据剩余比例返回状态色（与 QuotaModels.swift statusColor 一致）
const statusColor = (f: number) =>
  f === 0 ? "var(--status-red)" : f <= 0.3 ? "var(--status-orange)" : "var(--status-green)";

// 每个 provider 的最差 quota（用于菜单栏 bar 高度）
const minFraction = (p: (typeof providers)[number]) =>
  Math.min(...p.quotas.map((q) => q.fraction));
---

{/* ============== dropdown 面板（两种 variant 共用） ============== */}
<div class:list={["dropdown", `dropdown--${variant}`]} role="img" aria-label="Quota Bar 下拉面板预览">
  <div class="dropdown__header">
    <div class="dropdown__title-group">
      <span class="dropdown__title">Quota Bar</span>
      <span class="dropdown__subtitle">6 项已连接 · 已更新于刚刚</span>
    </div>
    <div class="dropdown__refresh" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M11.5 7a4.5 4.5 0 1 1-1.32-3.18M11.5 1.5V4h-2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </div>
  </div>

  <div class="dropdown__list">
    {
      providers.map((p) => (
        <section class="provider">
          <header class="provider__head">
            <span class="provider__dot" style={`background:${p.color}`} />
            <span class="provider__name">{p.name}</span>
            {p.tier && <span class="provider__tier">{p.tier}</span>}
            <span class="provider__price">$20/月</span>
          </header>
          <div class="provider__quotas">
            {p.quotas.map((q) => (
              <div class="quota">
                <div class="quota__row">
                  <span class="quota__label">{q.label}</span>
                  <span class="quota__pct" style={`color:${statusColor(q.fraction)}`}>
                    {Math.round(q.fraction * 100)}%
                  </span>
                </div>
                <div class="quota__track">
                  <div
                    class="quota__fill"
                    style={`width:${q.fraction * 100}%;background-color:${statusColor(q.fraction)}`}
                  />
                </div>
              </div>
            ))}
          </div>
        </section>
      ))
    }
  </div>

  <footer class="dropdown__footer">
    <span>打开设置…</span>
    <span class="dropdown__hint">拖拽以排序</span>
  </footer>
</div>

{/* ============== Hero 版：菜单栏横条 + dropdown 浮层组合 ============== */}
{variant === "hero" ? (
  <div class="hero-mockup" role="img" aria-label="Quota Bar 菜单栏预览">
    <div class="menubar">
      <div class="menubar__left">
        <span class="menubar__logo" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <rect x="1" y="1" width="14" height="14" rx="4" fill="var(--brand)"></rect>
            <rect x="3" y="5" width="10" height="1.5" rx="0.75" fill="#fff"></rect>
            <rect x="3" y="7.5" width="10" height="1.5" rx="0.75" fill="rgba(255,255,255,0.3)"></rect>
            <rect x="3" y="7.5" width="6" height="1.5" rx="0.75" fill="#fff"></rect>
            <rect x="3" y="10" width="10" height="1.5" rx="0.75" fill="rgba(255,255,255,0.3)"></rect>
            <rect x="3" y="10" width="2.5" height="1.5" rx="0.75" fill="#FFD60A"></rect>
          </svg>
        </span>
        <span class="menubar__appname">Quota Bar</span>
      </div>

      <div class="menubar__right">
        <div class="menubar__bars">
          {providers.map((p) => {
            const minF = minFraction(p);
            const pct = Math.round(minF * 100);
            return (
              <span class="bar-stack" title={`${p.name} ${pct}%`}>
                <span
                  class="bar-stack__fill"
                  style={`height:${Math.max(8, minF * 100)}%;background:${statusColor(minF)}`}
                />
              </span>
            );
          })}
        </div>
        <span class="menubar__clock">9:41</span>
      </div>
    </div>

    <div class="hero-mockup__dropdown-wrap" aria-hidden="true">
      <div class="dropdown dropdown--mini">
        <div class="dropdown__header">
          <div class="dropdown__title-group">
            <span class="dropdown__title">Quota Bar</span>
            <span class="dropdown__subtitle">6 项已连接</span>
          </div>
          <div class="dropdown__refresh">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M11.5 7a4.5 4.5 0 1 1-1.32-3.18M11.5 1.5V4h-2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
        </div>
        <div class="dropdown__list">
          {providers.map((p) => (
            <section class="provider">
              <header class="provider__head">
                <span class="provider__dot" style={`background:${p.color}`} />
                <span class="provider__name">{p.name}</span>
                {p.tier && <span class="provider__tier">{p.tier}</span>}
                <span class="provider__price">$20/月</span>
              </header>
              <div class="provider__quotas">
                {p.quotas.map((q) => (
                  <div class="quota">
                    <div class="quota__row">
                      <span class="quota__label">{q.label}</span>
                      <span class="quota__pct" style={`color:${statusColor(q.fraction)}`}>
                        {Math.round(q.fraction * 100)}%
                      </span>
                    </div>
                    <div class="quota__track">
                      <div
                        class="quota__fill"
                        style={`width:${q.fraction * 100}%;background-color:${statusColor(q.fraction)}`}
                      />
                    </div>
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </div>
) : null}

<style>
  /* ============== dropdown 面板 ============== */
  .dropdown {
    width: 340px;
    background: var(--bg-glass);
    backdrop-filter: blur(40px) saturate(1.4);
    -webkit-backdrop-filter: blur(40px) saturate(1.4);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    font-family: var(--font-sans);
  }

  .dropdown--standalone {
    width: 380px;
  }

  .dropdown--mini {
    width: 320px;
  }

  .dropdown__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--divider);
  }

  .dropdown__title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .dropdown__subtitle {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    margin-top: 2px;
  }

  .dropdown__refresh {
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
  }

  .dropdown__list {
    max-height: 460px;
    overflow-y: auto;
    padding: var(--space-2);
  }

  .dropdown--mini .dropdown__list {
    max-height: 420px;
  }

  /* —— provider 区块 —— */
  .provider {
    padding: var(--space-3);
    border-radius: var(--radius-md);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .provider:hover {
    background: rgba(0, 0, 0, 0.03);
  }

  .provider + .provider {
    margin-top: var(--space-1);
  }

  .provider__head {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .provider__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.6);
  }

  .provider__name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .provider__tier {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    background: rgba(0, 0, 0, 0.05);
    padding: 1px 6px;
    border-radius: var(--radius-pill);
  }

  .provider__price {
    margin-left: auto;
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    font-variant-numeric: tabular-nums;
  }

  /* —— quota 进度条 —— */
  .provider__quotas {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: 16px;
  }

  .quota__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 4px;
  }

  .quota__label {
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  .quota__pct {
    font-size: var(--text-xs);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .quota__track {
    height: 6px;
    background: rgba(0, 0, 0, 0.07);
    border-radius: var(--radius-pill);
    overflow: hidden;
  }

  .quota__fill {
    height: 100%;
    border-radius: var(--radius-pill);
    transition: width 0.8s var(--ease-out);
  }

  /* —— footer —— */
  .dropdown__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--divider);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .dropdown__hint {
    opacity: 0.7;
  }

  /* ============== Hero 版：菜单栏 + dropdown 组合 ============== */
  .hero-mockup {
    position: relative;
    width: 100%;
    max-width: 720px;
  }

  .menubar {
    height: 28px;
    background: var(--bg-menu-bar);
    backdrop-filter: blur(20px) saturate(1.5);
    -webkit-backdrop-filter: blur(20px) saturate(1.5);
    border: 1px solid var(--border);
    border-bottom: 1px solid var(--divider);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-3);
    font-size: 13px;
  }

  .menubar__left {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .menubar__logo {
    display: flex;
  }

  .menubar__appname {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .menubar__right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }

  /* —— 核心：菜单栏 vertical progress bar 组 —— */
  .menubar__bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 16px;
  }

  .bar-stack {
    width: 4px;
    height: 16px;
    background: rgba(0, 0, 0, 0.1);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
    display: inline-block;
  }

  .bar-stack__fill {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    border-radius: 2px;
    transition: height 1s var(--ease-out);
    animation: bar-breathe 4s var(--ease-out) infinite;
  }

  /* 错开动画相位，营造此起彼伏的"实时刷新"感 */
  .bar-stack:nth-child(1) .bar-stack__fill { animation-delay: 0s; }
  .bar-stack:nth-child(2) .bar-stack__fill { animation-delay: 0.4s; }
  .bar-stack:nth-child(3) .bar-stack__fill { animation-delay: 0.8s; }
  .bar-stack:nth-child(4) .bar-stack__fill { animation-delay: 1.2s; }
  .bar-stack:nth-child(5) .bar-stack__fill { animation-delay: 1.6s; }
  .bar-stack:nth-child(6) .bar-stack__fill { animation-delay: 2.0s; }

  @keyframes bar-breathe {
    0%, 100% { opacity: 1; filter: brightness(1); }
    50% { opacity: 0.65; filter: brightness(1.15); }
  }

  .menubar__clock {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
  }

  .hero-mockup__dropdown-wrap {
    position: absolute;
    top: 32px;
    right: var(--space-3);
    animation: dropdown-float 6s var(--ease-out) infinite;
  }

  @keyframes dropdown-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* ============== 响应式 ============== */
  @media (max-width: 768px) {
    .dropdown,
    .dropdown--standalone,
    .dropdown--mini {
      width: 100%;
      max-width: 340px;
    }

    .hero-mockup__dropdown-wrap {
      position: relative;
      top: auto;
      right: auto;
      margin-top: var(--space-4);
      display: flex;
      justify-content: center;
    }

    @keyframes dropdown-float {
      0%, 100% { transform: none; }
      50% { transform: none; }
    }
  }
</style>
