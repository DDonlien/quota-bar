---
import MenuBarMockup from "./MenuBarMockup.astro";

const steps = [
  {
    n: "01",
    title: "自动探测",
    desc: "启动时扫描本机已安装的 CLI、桌面 App 和浏览器登录态，无需你做任何配置。识别到什么，就连接什么。",
  },
  {
    n: "02",
    title: "本地读取额度",
    desc: "所有额度数据都在你的 Mac 上读取，不经过任何第三方服务器。浏览器 Cookie 也只在本地解析。",
  },
  {
    n: "03",
    title: "菜单栏即时呈现",
    desc: "把每个服务的剩余额度做成进度条，直接画进菜单栏。一眼看到，无需打开应用窗口。",
  },
];
---

<section id="how-it-works" class="section showcase-section">
  <div class="container">
    <div class="showcase__layout">
      <div class="showcase__visual reveal">
        <div class="showcase__device">
          <MenuBarMockup variant="standalone" />
        </div>
      </div>

      <div class="showcase__content">
        <header class="reveal">
          <span class="section__eyebrow">工作原理</span>
          <h2 class="section__title">三步完成，全程透明</h2>
          <p class="section__subtitle">
            没有云服务、没有账号体系、没有数据上传。Quota Bar 是一个纯粹的本地应用。
          </p>
        </header>

        <ol class="steps reveal">
          {
            steps.map((s) => (
              <li class="step">
                <span class="step__num">{s.n}</span>
                <div class="step__body">
                  <h3 class="step__title">{s.title}</h3>
                  <p class="step__desc">{s.desc}</p>
                </div>
              </li>
            ))
          }
        </ol>

        <div class="showcase__note reveal">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1l2 5h5l-4 3 1.5 5L8 11l-4.5 3L5 9 1 6h5l2-5z" fill="var(--brand)"/>
          </svg>
          <span>所有额度数据本地解析、本地存储，离开你的 Mac 不走一米。</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase-section {
    background:
      radial-gradient(ellipse 60% 40% at 80% 50%, rgba(10, 124, 255, 0.06), transparent 70%),
      var(--bg);
  }

  .showcase__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  .showcase__visual {
    display: flex;
    justify-content: center;
  }

  .showcase__device {
    position: relative;
  }

  .showcase__device::before {
    content: "";
    position: absolute;
    inset: -40px;
    background: radial-gradient(circle, rgba(10, 124, 255, 0.12), transparent 60%);
    z-index: -1;
    border-radius: 50%;
  }

  .showcase__content .section__header {
    align-items: flex-start;
    text-align: left;
    margin-bottom: var(--space-6);
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .step {
    display: flex;
    gap: var(--space-4);
  }

  .step__num {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--brand-soft);
    color: var(--brand);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
  }

  .step__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .step__desc {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .showcase__note {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  @media (max-width: 960px) {
    .showcase__layout {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }

    .showcase__content .section__header {
      align-items: center;
      text-align: center;
    }
  }
</style>
