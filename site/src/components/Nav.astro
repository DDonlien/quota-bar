---
import LocaleSwitcher from "./LocaleSwitcher.astro";
// 静态 fallback href：build 时 hardcode 当前最新 nightly release 的 .dmg URL。
// 这样无 JS / 首屏加载前的点击也会直击 .dmg 而不是落到 /releases 列表页。
// 客户端 <script> 后续会在 fetch 出更新的 release 时再覆盖一次（`UPDATE_DOWNLOAD` in index.astro）。
const LATEST_DMG_URL =
  "https://github.com/DDonlien/quota-bar/releases/download/nightly-c6317d05cfe8217aef54324ce193070a5dc29d84/QuotaBar-c6317d0.dmg";
---

<!-- BEGIN: MainHeader (logo 左 / lang + download 右，窄屏不堆叠) -->
<header class="site-nav">
  <div class="site-nav__inner">
    <a href="/" class="site-nav__logo" aria-label="Quota Bar">
      <img
        src="/logo-512.png"
        alt=""
        width="24"
        height="24"
        class="site-nav__logo-img"
      />
      <span class="site-nav__name">QUOTA BAR</span>
    </a>

    <nav class="site-nav__actions" aria-label="Header">
      <a
        class="site-nav__link site-nav__link--secondary"
        href="/changelog"
        data-i18n="nav.changelog"
      >Changelog</a>
      <LocaleSwitcher />
      <a
        class="site-nav__download"
        href={LATEST_DMG_URL}
        target="_blank"
        rel="noopener"
        data-download
        data-i18n-aria="nav.download"
        aria-label="Download"
      >
        <svg
          class="site-nav__download-icon"
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.23-.02-.3-.03-.01-.06-.04-.22-.04-.39 0-1.15.572-2.27 1.206-2.98.804-.94 2.19-1.64 3.334-1.68.03.13.04.28.04.43zm4.565 15.71c-.03.07-.463 1.58-1.518 3.12-.945 1.34-1.94 2.71-3.43 2.71-1.517 0-1.9-.88-3.63-.88-1.698 0-2.302.91-3.67.91-1.377 0-2.332-1.26-3.428-2.8-1.287-1.82-2.323-4.63-2.323-7.28 0-4.28 2.797-6.55 5.552-6.55 1.448 0 2.675.95 3.6.95.865 0 2.222-1.01 3.902-1.01.613 0 2.886.06 4.374 2.19-.13.09-2.383 1.37-2.383 4.19 0 3.26 2.854 4.42 2.955 4.45z"/>
        </svg>
        <span class="site-nav__download-text" data-i18n="nav.download">Download</span>
      </a>
    </nav>
  </div>
</header>
<!-- END: MainHeader -->

<style>
  /* Header 视觉撑满 viewport（fixed + backdrop-blur 覆盖整个宽度），但 inner 用与
   * container-content 同样的 1060px max-width + 居中，让 logo / actions 跟下面
   * section（hero / product preview）的左右边线对齐。 */
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--bg-header);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    /* 不再用横线分隔：靠 backdrop-blur 本身的透明渐隐融进页面背景，
     * 更贴近 macOS 26 菜单栏那种"没有硬边界"的悬浮感。 */
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-6);  /* 固定 24px 横向 padding，与 container 一致 */
    width: 100%;
    max-width: var(--max-w-content);       /* 1060px — 与 hero / product preview 对齐 */
    margin-inline: auto;
  }

  .site-nav__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .site-nav__logo-img {
    width: 24px;
    height: 24px;
    display: block;
    border-radius: 6px;
  }

  .site-nav__name {
    font-weight: 500;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);  /* 12px */
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .site-nav__actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .site-nav__link {
    font-size: var(--text-sm);  /* 13px */
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: color var(--duration-fast) var(--ease-out);
    white-space: nowrap;
  }
  .site-nav__link:hover {
    color: var(--text-primary);
  }

  .site-nav__download {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);  /* 8px — icon + 文字 */
    padding: var(--space-2) var(--space-3);
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);  /* 13px */
    font-weight: 500;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: background var(--duration-fast) var(--ease-out);
  }
  /* SVG icon flex item 在 inline-flex container 内 baseline 的兜底：
   * 避免按钮高度被 svg line-height 撑开 */
  .site-nav__download-icon { display: block; flex-shrink: 0; }
  .site-nav__download:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  /* 窄屏（<640px）：隐藏 Changelog 链接 + 收紧 actions gap + Download 文字在小屏藏起来只显图标 */
  @media (max-width: 640px) {
    .site-nav__link--secondary { display: none; }
    .site-nav__actions { gap: var(--space-3); }
    .site-nav__download {
      padding: var(--space-2);
    }
    .site-nav__download-text { display: none; }
  }
</style>