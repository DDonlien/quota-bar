---
import LocaleSwitcher from "./LocaleSwitcher.astro";
const REPO = "DDonlien/quota-bar";
---

<!-- BEGIN: MainHeader (vibeisland 风格：fixed + 半透明 + backdrop-blur) -->
<header class="site-nav">
  <div class="site-nav__inner container-content">
    <a href="/" class="site-nav__logo" aria-label="Quota Bar">
      <span class="site-nav__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="6" width="20" height="2" rx="1" fill="currentColor" opacity="0.9"/>
          <rect x="2" y="11" width="14" height="2" rx="1" fill="currentColor" opacity="0.7"/>
          <rect x="2" y="16" width="8" height="2" rx="1" fill="currentColor" opacity="0.5"/>
        </svg>
      </span>
      <span class="site-nav__name">QUOTA BAR</span>
    </a>

    <nav class="site-nav__actions" aria-label="Header">
      <a
        class="site-nav__link"
        href={`https://github.com/${REPO}/blob/main/CHANGELOG.md`}
        target="_blank"
        rel="noopener"
        data-i18n="nav.changelog"
      >Changelog</a>
      <LocaleSwitcher />
      <a
        class="site-nav__download"
        href={`https://github.com/${REPO}/releases`}
        target="_blank"
        rel="noopener"
        data-download
      >
        <svg fill="currentColor" height="12" viewBox="0 0 24 24" width="12" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        <span data-i18n="nav.download">Download</span>
      </a>
    </nav>
  </div>
</header>
<!-- END: MainHeader -->

<style>
  /* 参考 vibeisland.app .v6-nav：fixed + 半透明 + backdrop-blur
   * 节奏：18px top padding / 28px bottom padding / 13px nav link / 12px brand
   */
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--bg-header);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-3);  /* 12px — 紧凑 */
  }

  .site-nav__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-primary);
  }

  .site-nav__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }

  .site-nav__name {
    font-weight: 500;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);  /* 12px — vibeisland nav brand */
    text-transform: uppercase;
  }

  .site-nav__actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-5);  /* 20px */
    color: var(--text-tertiary);
  }

  .site-nav__link {
    font-size: var(--text-sm);  /* 13px */
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .site-nav__link:hover {
    color: var(--text-primary);
  }

  .site-nav__download {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);  /* 8px 12px */
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);  /* 13px */
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: background var(--duration-fast) var(--ease-out);
  }
  .site-nav__download:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  @media (max-width: 640px) {
    .site-nav__actions {
      gap: var(--space-3);
    }
  }
</style>