---
// 6 张 Feature 卡。结构 + 图标 → 数组循环渲染，避免 6 段重复 markup。
// 节奏：vibeisland 960 容器 / 20px 网格 gap / 24px 卡片 padding / 12px 圆角
//
// 移除掉的 3 项（feature.2 菜单栏集成 / feature.8 一键查看详情 / feature.9 自由排序）
// 都已经在 Product Preview 的 3 个 tab（总览 / 详情 / 调整）里覆盖了，所以这里不重复展示。
const FEATURES: { titleKey: string; descKey: string; icon: string }[] = [
  { titleKey: "feature.1.title", descKey: "feature.1.desc", icon: "layers" },
  { titleKey: "feature.4.title", descKey: "feature.4.desc", icon: "dollar" },
  { titleKey: "feature.5.title", descKey: "feature.5.desc", icon: "lock" },
  { titleKey: "feature.6.title", descKey: "feature.6.desc", icon: "refresh" },
  { titleKey: "feature.7.title", descKey: "feature.7.desc", icon: "app-window" },
  { titleKey: "feature.3.title", descKey: "feature.3.desc", icon: "bell" },
];
---

<!-- BEGIN: Features Grid -->
<section class="features section">
  <div class="container-features">
    <div class="features__grid">
      {FEATURES.map((f) => (
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            {f.icon === "layers" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
              </svg>
            )}
            {f.icon === "monitor" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <rect height="14" rx="2" ry="2" width="20" x="2" y="3"></rect>
                <line x1="8" x2="16" y1="21" y2="21"></line>
                <line x1="12" x2="12" y1="17" y2="21"></line>
              </svg>
            )}
            {f.icon === "bell" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
            )}
            {f.icon === "dollar" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
              </svg>
            )}
            {f.icon === "lock" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <rect height="11" rx="2" ry="2" width="18" x="3" y="11"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            )}
            {f.icon === "refresh" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"></path>
              </svg>
            )}
            {f.icon === "moon" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            )}
            {f.icon === "app-window" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20" aria-hidden="true">
                <rect x="3" y="4" width="18" height="16" rx="3"></rect>
                <line x1="3" y1="9" x2="21" y2="9"></line>
              </svg>
            )}
            {f.icon === "target" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            )}
            {f.icon === "key" && (
              <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
              </svg>
            )}
            {f.icon === "grip" && (
              <svg fill="currentColor" height="20" viewBox="0 0 24 24" width="20" aria-hidden="true">
                <circle cx="9" cy="6" r="1.4"></circle>
                <circle cx="15" cy="6" r="1.4"></circle>
                <circle cx="9" cy="12" r="1.4"></circle>
                <circle cx="15" cy="12" r="1.4"></circle>
                <circle cx="9" cy="18" r="1.4"></circle>
                <circle cx="15" cy="18" r="1.4"></circle>
              </svg>
            )}
          </div>
          <h3 class="feature-card__title" data-i18n={f.titleKey}></h3>
          <p class="feature-card__desc" data-i18n={f.descKey}></p>
        </article>
      ))}
    </div>
  </div>
</section>
<!-- END: Features Grid -->

<style>
  /* vibeisland 9 宫格：暗色 + 1px 浅边框 + 12px 圆角 + 内容居中
   * hover：translateY(-3px) + 边框暖橙 + 图标着色 + 阴影加深
   * 响应式：桌面 3 列 / 平板 2 列 / 手机 2 列紧凑（保留九宫格感）
   */
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);  /* 20px */
  }
  @media (max-width: 900px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);  /* 16px */
    }
  }
  @media (max-width: 480px) {
    .features__grid {
      gap: var(--space-3);  /* 12px */
    }
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-6);  /* 24px */
    background: var(--bg-glass);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);  /* 12px */
    transition:
      transform 220ms var(--ease-out),
      border-color 220ms ease,
      background 220ms ease,
      box-shadow 220ms ease;
    cursor: default;
  }
  .feature-card:hover {
    transform: translateY(-3px);
    background: rgba(30, 30, 34, 0.7);
    border-color: rgba(217, 119, 87, 0.55);
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(217, 119, 87, 0.15);
  }

  .feature-card__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);  /* 8px */
    margin-bottom: var(--space-5);  /* 20px */
    transition:
      color 220ms ease,
      background 220ms ease,
      border-color 220ms ease;
  }
  .feature-card:hover .feature-card__icon {
    color: var(--accent);
    background: var(--accent-soft);
    border-color: rgba(217, 119, 87, 0.4);
  }

  /* 2 列布局下，最后一张卡是 odd 时跨 2 列但宽度限制到 50% 居中，
   * 避免最后一行单卡孤岛。 */
  @media (max-width: 900px) {
    .feature-card:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      width: calc(50% - var(--space-4) / 2);
      justify-self: center;
    }
  }

  .feature-card__title {
    font-size: var(--text-base);  /* 14px */
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-2);  /* 8px */
    letter-spacing: 0.01em;
  }

  .feature-card__desc {
    font-size: var(--text-xs);  /* 12px */
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 32ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card,
    .feature-card__icon {
      transition: none;
    }
    .feature-card:hover {
      transform: none;
    }
  }
</style>