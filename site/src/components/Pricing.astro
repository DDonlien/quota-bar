---
// Pricing — vibeisland 节奏：380px 容器 / 36px 卡片 padding / 48px 大数字
---

<!-- BEGIN: Pricing Section -->
<section class="pricing section">
  <div class="container-content">
    <div class="pricing__header">
      <h2 class="pricing__heading">
        <span data-i18n="pricing.heading">Ready to upgrade your workflow?</span>
      </h2>
      <p class="pricing__subheading">
        <span data-i18n="pricing.subheading">One-time purchase. No subscriptions.</span>
      </p>
    </div>

    <div class="pricing__card-wrap">
      <div class="pricing__card">
        <div class="pricing__glow" aria-hidden="true"></div>

        <div class="pricing__plan">
          <h3 class="pricing__plan-name">
            <span data-i18n="pricing.plan.name">Quota Bar Pro</span>
          </h3>
          <div class="pricing__amount">
            <span class="pricing__amount-current">$9.99</span>
            <span class="pricing__amount-old">$14.99</span>
          </div>
        </div>

        <p class="pricing__note">
          <span data-i18n="pricing.plan.note">Lifetime license</span>
        </p>

        <ul class="pricing__bullets">
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.bullet.unlimited">Unlimited Services Tracking</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.bullet.alerts">Advanced Custom Alerts</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.bullet.support">Priority Support</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.bullet.updates">Unlimited sessions & future updates</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.bullet.swift">Native Swift Performance</span>
          </li>
        </ul>

        <button class="pricing__cta" type="button">
          <span data-i18n="pricing.cta">Get Quota Bar Pro</span>
        </button>

        <p class="pricing__support">
          <span data-i18n="pricing.support.hint">Payment issues? hi@quotabar.app</span>
        </p>
      </div>
    </div>
  </div>
</section>
<!-- END: Pricing Section -->

<style>
  .pricing__header {
    text-align: center;
    margin-bottom: var(--space-7);  /* 32px */
  }

  .pricing__heading {
    font-size: var(--text-2xl);  /* 24px — section 修饰标题 */
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.005em;
    margin-bottom: var(--space-2);  /* 8px */
  }
  @media (max-width: 768px) {
    .pricing__heading {
      font-size: var(--text-3xl);  /* 28px mobile */
    }
  }

  .pricing__subheading {
    font-size: var(--text-base);  /* 14px */
    color: var(--text-secondary);
  }

  .pricing__card-wrap {
    display: flex;
    justify-content: center;
  }

  .pricing__card {
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: var(--max-w-pricing);  /* 380px */
    padding: var(--space-7);  /* 32px — 偏紧 vibeisland */
    background: var(--bg-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);  /* 16px */
  }

  /* 右上角装饰光晕 */
  .pricing__glow {
    position: absolute;
    top: -2.5rem;
    right: -2.5rem;
    width: 8rem;
    height: 8rem;
    background: radial-gradient(circle, rgba(255, 140, 0, 0.18) 0%, rgba(15, 15, 17, 0) 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  /* Plan 行：plan-name 左 + amount 右，row + wrap 防溢出。
   * 关键：plan-name 必须 white-space: nowrap，否则 "Quota Bar Pro"
   * 在 380px 容器里会被迫换行成 "Quota Bar / Pro"。
   * min-width: 0 + flex-shrink: 1 让 amount 优先收缩。
   */
  .pricing__plan {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .pricing__plan-name {
    font-size: var(--text-md);  /* 15px */
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 0.01em;
    white-space: nowrap;
    flex-shrink: 1;
    min-width: 0;
  }

  .pricing__amount {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pricing__amount-current {
    font-size: var(--text-4xl);  /* 48px */
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .pricing__amount-old {
    font-size: var(--text-md);  /* 15px */
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .pricing__note {
    font-size: var(--text-xs);  /* 12px */
    color: var(--text-muted);
    margin-bottom: var(--space-6);  /* 24px */
  }

  .pricing__bullets {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);  /* 12px */
    margin-bottom: var(--space-7);  /* 32px */
    font-size: var(--text-sm);  /* 13px */
    line-height: 1.5;
    color: var(--text-secondary);
  }
  .pricing__bullets li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .pricing__check {
    color: var(--success);
    margin-top: 3px;
    flex-shrink: 0;
  }

  .pricing__cta {
    display: block;
    width: 100%;
    padding: 12px 28px;
    background: #ffffff;
    color: #000000;
    font-weight: 500;
    font-size: var(--text-base);  /* 14px */
    border-radius: var(--radius-md);  /* 12px */
    transition: background var(--duration-fast) var(--ease-out);
    margin-bottom: var(--space-3);
  }
  .pricing__cta:hover {
    background: #f0f0f0;
  }

  .pricing__support {
    text-align: center;
    font-size: var(--text-xs);  /* 12px */
    color: var(--text-muted);
    margin-top: var(--space-3);
  }
</style>