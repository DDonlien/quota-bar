---
// Pricing — vibeisland 节奏：380px 容器 / 36px 卡片 padding / 48px 大数字
---

<!-- BEGIN: Pricing Section -->
<section class="pricing section" id="pricing">
  <div class="container-content">
    <div class="pricing__header">
      <h2 class="pricing__heading">
        <span data-i18n="pricing.heading">Quota Bar Pro — $4.99, one time</span>
      </h2>
      <p class="pricing__subheading">
        <span data-i18n="pricing.subheading">Every download includes a full 7-day free trial of Pro — no credit card required.</span>
      </p>
    </div>

    <div class="pricing__card-wrap">
      <div class="pricing__card pricing__card--outline">
        <span class="pricing__badge pricing__badge--neutral" data-i18n="pricing.opensource.badge">Open Source</span>

        <div class="pricing__plan">
          <h3 class="pricing__plan-name">
            <span data-i18n="pricing.opensource.plan.name">Build it yourself</span>
          </h3>
          <div class="pricing__amount">
            <span class="pricing__amount-current" data-i18n="pricing.opensource.amount">Free</span>
          </div>
        </div>

        <p class="pricing__note">
          <span data-i18n="pricing.opensource.note">Full source on GitHub · same features</span>
        </p>

        <ul class="pricing__bullets">
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.opensource.bullet.source">Complete, unrestricted source code</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.opensource.bullet.community">Community support via GitHub Issues</span>
          </li>
        </ul>

        <a class="pricing__cta pricing__cta--outline" href="https://github.com/DDonlien/quota-bar" target="_blank" rel="noopener">
          <span data-i18n="pricing.opensource.cta">View on GitHub</span>
        </a>

        <!-- 隐形占位——付费卡 CTA 下面还有一行支付提示文字，把按钮往上顶；这张卡没有对应内容，
             用同高度的占位段落补上，保证两个 CTA 按钮贴同一条水平线，不是靠肉眼调 margin 凑。 -->
        <p class="pricing__support pricing__support--placeholder" aria-hidden="true">&nbsp;</p>
      </div>

      <div class="pricing__card">
        <div class="pricing__glow" aria-hidden="true"></div>

        <span class="pricing__badge" data-i18n="pricing.badge">7-Day Free Trial</span>

        <div class="pricing__plan">
          <h3 class="pricing__plan-name">
            <span data-i18n="pricing.plan.name">Quota Bar Pro</span>
          </h3>
          <div class="pricing__amount">
            <span class="pricing__amount-current">$4.99</span>
          </div>
        </div>

        <p class="pricing__note">
          <span data-i18n="pricing.plan.note">One-time purchase · includes future updates</span>
        </p>

        <ul class="pricing__bullets">
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.opensource.bullet.source">Complete, unrestricted source code</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.opensource.bullet.community">Community support via GitHub Issues</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.bullet.autoupdate">Automatic updates</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.bullet.oneclick">One-click install</span>
          </li>
          <li>
            <svg class="pricing__check" fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span data-i18n="pricing.bullet.support">Priority Support</span>
          </li>
        </ul>

        <button class="pricing__cta" type="button">
          <span data-i18n="pricing.cta">Start Free Trial</span>
        </button>

        <p class="pricing__support">
          <span data-i18n="pricing.support.hint">Payment issues? taobe@ddonlien.com</span>
        </p>
      </div>
    </div>
  </div>
</section>
<!-- END: Pricing Section -->

<style>
  .pricing__header {
    text-align: center;
    margin-bottom: var(--space-7);  /* 32px */
  }

  .pricing__heading {
    font-size: var(--text-2xl);  /* 24px — section 修饰标题 */
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.005em;
    margin-bottom: var(--space-2);  /* 8px */
  }
  @media (max-width: 768px) {
    .pricing__heading {
      font-size: var(--text-3xl);  /* 28px mobile */
    }
  }

  .pricing__subheading {
    font-size: var(--text-base);  /* 14px */
    color: var(--text-secondary);
  }

  /* 两卡并排：≥768px 左右并排（开源在左、付费在右，跟 Hero 的
   * "先引导 GitHub 自编译，再看付费版" 顺序一致）；<768px 堆叠。
   * align-items: stretch 让两张卡高度一致，视觉上是平级选项，不是主次关系。 */
  .pricing__card-wrap {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: stretch;
    gap: var(--space-6);  /* 24px */
  }

  .pricing__card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: var(--max-w-pricing);  /* 380px */
    padding: var(--space-7);  /* 32px — 偏紧 vibeisland */
    background: var(--bg-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);  /* 16px */
  }

  /* 开源卡片：跟付费卡同尺寸同结构，只是不用暖橙强调（那是付费卡的"限时"信号），
   * 边框稍弱一点，视觉上安静地并排存在，而不是抢主卡的注意力。 */
  .pricing__card--outline {
    border-color: var(--border-strong);
  }

  /* 右上角装饰光晕 */
  .pricing__glow {
    position: absolute;
    top: -2.5rem;
    right: -2.5rem;
    width: 8rem;
    height: 8rem;
    background: radial-gradient(circle, rgba(255, 140, 0, 0.18) 0%, rgba(15, 15, 17, 0) 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  /* 「限时免费」徽标：暖橙底 + 深橙字，压在卡片顶部、plan 行上方 */
  .pricing__badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    margin-bottom: var(--space-4);  /* 16px */
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid rgba(255, 140, 0, 0.35);
    border-radius: var(--radius-pill);
    font-size: var(--text-xs);  /* 12px */
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  /* 开源徽标：中性灰而不是暖橙——暖橙是付费卡"限时"的专属信号，
   * 开源这条路径本身不需要制造紧迫感。 */
  .pricing__badge--neutral {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
    border-color: var(--border-strong);
  }

  /* Plan 行：plan-name 左 + amount 右，row + wrap 防溢出。
   * 关键：plan-name 必须 white-space: nowrap，否则 "Quota Bar Pro"
   * 在 380px 容器里会被迫换行成 "Quota Bar / Pro"。
   * min-width: 0 + flex-shrink: 1 让 amount 优先收缩。
   */
  .pricing__plan {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .pricing__plan-name {
    font-size: var(--text-md);  /* 15px */
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 0.01em;
    white-space: nowrap;
    flex-shrink: 1;
    min-width: 0;
  }

  .pricing__amount {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pricing__amount-current {
    font-size: var(--text-4xl);  /* 48px */
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .pricing__note {
    font-size: var(--text-xs);  /* 12px */
    color: var(--text-muted);
    margin-bottom: var(--space-6);  /* 24px */
  }

  .pricing__bullets {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);  /* 12px */
    margin-bottom: var(--space-7);  /* 32px */
    font-size: var(--text-sm);  /* 13px */
    line-height: 1.5;
    color: var(--text-secondary);
  }
  .pricing__bullets li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .pricing__check {
    color: var(--success);
    margin-top: 3px;
    flex-shrink: 0;
  }

  .pricing__cta {
    display: block;
    width: 100%;
    padding: 12px 28px;
    background: #ffffff;
    color: #000000;
    font-weight: 500;
    font-size: var(--text-base);  /* 14px */
    border-radius: var(--radius-md);  /* 12px */
    text-align: center;
    transition: background var(--duration-fast) var(--ease-out);
    margin-bottom: var(--space-3);
    /* .pricing__cta 现在也用在 <a> 上（开源卡跳 GitHub），撑住 flex 卡片底部对齐。 */
    margin-top: auto;
  }
  .pricing__cta:hover {
    background: #f0f0f0;
  }

  /* 开源卡的 CTA：outline 而不是实心白——两张卡视觉平级，但同一行并排放两个
   * 实心白按钮会显得重复；outline 是"同样重要、路径不同"的常规表达，不是弱化。 */
  .pricing__cta--outline {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-strong);
  }
  .pricing__cta--outline:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  .pricing__support {
    text-align: center;
    font-size: var(--text-xs);  /* 12px */
    color: var(--text-muted);
    margin-top: var(--space-3);
  }

  /* 只占位、不可见：撑出跟付费卡支付提示行一样的高度，让两张卡的 CTA 按钮对齐到
   * 同一条水平线，见上面 HTML 里的说明。 */
  .pricing__support--placeholder {
    visibility: hidden;
  }
</style>