---
// SupportedServices — 一行 provider pills + 一行 app/web/cli 说明
// 节奏：container-content 1060px / 居中 / 紧凑
// 列表项跟 Hero typewriter / Layout description 保持一致（6 个，含 zcode）；
// zcode 在 macOS 端 v0.7.0 接入中（v0.4.0 数据调研已落地），site 先行列出。
const PROVIDERS = ["Antigravity", "Codex", "Claude", "MiniMax", "Kimi", "Zcode"];
---

<!-- BEGIN: Supported Services Section -->
<section class="supported-services section">
  <div class="container-content">
    <h2 class="supported-services__heading" data-i18n="services.heading">
      支持哪些服务
    </h2>

    <div class="supported-services__pills" role="list">
      {PROVIDERS.map((name) => (
        <span class="supported-services__pill" role="listitem">{name}</span>
      ))}
    </div>

    <p class="supported-services__note">
      <span data-i18n="services.note">使用 app、web 和 cli 时，能获取到的额度信息会有所不同。</span>
    </p>
  </div>
</section>
<!-- END: Supported Services Section -->

<style>
  .supported-services {
    /* 比 section 默认更紧凑：section 默认 48px y-padding，这里 32px 上下 */
    padding-block: var(--space-7);
  }

  .supported-services__heading {
    font-size: var(--text-2xl);  /* 24px — 与 section h2 一致 */
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.005em;
    text-align: center;
    margin-bottom: var(--space-6);  /* 24px */
    color: var(--text-primary);
  }
  @media (max-width: 768px) {
    .supported-services__heading {
      font-size: var(--text-3xl);  /* 28px mobile */
    }
  }

  .supported-services__pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);  /* 12px */
    margin-bottom: var(--space-5);  /* 20px */
  }

  .supported-services__pill {
    display: inline-flex;
    align-items: center;
    padding: 8px 18px;
    border-radius: var(--radius-pill);
    background: var(--bg-glass);
    border: 1px solid var(--border);
    font-size: var(--text-sm);  /* 13px */
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .supported-services__pill:hover {
    border-color: rgba(255, 140, 0, 0.55);
    background: rgba(255, 140, 0, 0.06);
    color: var(--accent);
  }

  .supported-services__note {
    text-align: center;
    font-size: var(--text-sm);  /* 13px */
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 56ch;
    margin: 0 auto;
  }
</style>