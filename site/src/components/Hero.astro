---
import MenuBarMockup from "./MenuBarMockup.astro";

const REPO = "DDonlien/quota-bar";
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <span class="hero__badge reveal">
        <span class="hero__badge-dot"></span>
        macOS 26 · 开源 · 本地优先
      </span>

      <h1 class="hero__title reveal">
        AI 订阅额度<br />
        <span class="hero__title-accent">一眼可见</span>
      </h1>

      <p class="hero__subtitle reveal">
        Quota Bar 把你所有 AI 服务的剩余额度，做成菜单栏里的进度条。<br />
        装上即用，免配置、免登录，无需打开任何窗口。
      </p>

      <div class="hero__cta reveal" id="download">
        <a
          class="btn btn--primary btn--lg"
          href={`https://github.com/${REPO}/releases`}
          data-download
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1v10m0 0L4 7m4 4l4-4M2 14h12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>免费下载 Quota Bar</span>
        </a>
        <a
          class="btn btn--ghost btn--lg"
          href={`https://github.com/${REPO}`}
          target="_blank"
          rel="noopener"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <div class="hero__meta reveal">
        <span>·  macOS 26+</span>
        <span>·  Apple Silicon / Intel</span>
        <span>·  开源免费</span>
      </div>
    </div>

    <div class="hero__visual reveal">
      <MenuBarMockup variant="hero" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-9);
    padding-bottom: var(--space-8);
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(10, 124, 255, 0.10), transparent 70%),
      var(--bg);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px 14px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-secondary);
    box-shadow: var(--shadow-sm);
    margin-bottom: var(--space-5);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--status-green);
    box-shadow: 0 0 0 3px rgba(53, 200, 90, 0.2);
  }

  .hero__title {
    font-size: var(--text-5xl);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-5);
    color: var(--text-primary);
  }

  .hero__title-accent {
    background: linear-gradient(120deg, var(--brand), #6ec1ff);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--text-secondary);
    margin-bottom: var(--space-7);
    max-width: 480px;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .btn--lg {
    padding: var(--space-4) var(--space-6);
    font-size: var(--text-lg);
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  @media (max-width: 960px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero__copy {
      text-align: center;
    }

    .hero__subtitle {
      margin-inline: auto;
    }

    .hero__cta,
    .hero__meta {
      justify-content: center;
    }

    .hero__title {
      font-size: var(--text-4xl);
    }
  }
</style>
