---
const REPO = "DDonlien/quota-bar";
// Hero 标题里轮播的 agent 名字：用 | 分隔。
//   - data-words-en / data-words-zh 是 i18n 的两条 fallback；当前两种语言都用同一组
//     英文专有名词，但保留双属性以便未来扩展（比如本地化名称）。
//   - data-typewords 由 Layout 在 locale 应用时动态设置（运行时中转属性）。
const AGENTS_EN = ["Antigravity", "Codex", "Claude", "MiniMax", "Kimi", "Zcode"];
const AGENTS_ZH = ["Antigravity", "Codex", "Claude", "MiniMax", "Kimi", "Zcode"];
const AGENTS_EN_JOINED = AGENTS_EN.join("|");
const AGENTS_ZH_JOINED = AGENTS_ZH.join("|");
---

<!-- BEGIN: Hero Section (vibeisland 节奏：60px 标题 + 180px 上 padding) -->
<section class="hero">
  <div class="hero__inner container-content">
    <h1 class="hero__title">
      <span data-i18n="hero.title.line1">Never lose track of</span><br />
      <span data-i18n="hero.title.lead">your</span>
      <span
        class="typing-text"
        data-typewriter="Antigravity"
        data-words-en={AGENTS_EN_JOINED}
        data-words-zh={AGENTS_ZH_JOINED}
        aria-live="polite"
      >Antigravity</span><span class="hero__tail" data-i18n="hero.title.tail">quotas</span>
    </h1>
    <p class="hero__subtitle">
      <span data-i18n="hero.subtitle">Stay ahead of limits without breaking your workflow.</span>
    </p>
    <div class="hero__ctas">
      <a
        href={`https://github.com/${REPO}/releases`}
        data-download
        class="hero__cta hero__cta--primary"
      >
        <svg fill="currentColor" height="16" viewBox="0 0 24 24" width="16">
          <path
            d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"
          ></path>
        </svg>
        <span data-i18n="hero.cta.download">Download for Free</span>
      </a>
      <a
        href={`https://github.com/${REPO}#readme`}
        target="_blank"
        rel="noopener"
        class="hero__cta hero__cta--ghost"
      >
        <span data-i18n="hero.cta.docs">View Documentation</span>
      </a>
    </div>
  </div>
</section>
<!-- END: Hero Section -->

<style>
  /* Hero 节奏：120px top padding / 20px bottom / 60px 标题 / 18px 副标
   * 120 = 60 (fixed nav) + 60 视觉留白；之前 180 偏空 */
  .hero {
    padding-top: 120px;
    padding-bottom: var(--space-5);  /* 20px */
  }
  @media (max-width: 768px) {
    .hero {
      padding-top: 96px;
      padding-bottom: var(--space-7);  /* 32px */
    }
  }

  .hero__inner {
    text-align: center;
  }

  .hero__title {
    /* mono 字体本身视觉够粗，weight 用 500；中英文混排自动按 lang 切换字体 */
    font-weight: 500;
    font-size: var(--text-5xl);  /* 60px */
    line-height: 76px;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-6);  /* 24px */
    white-space: nowrap;
    color: var(--text-primary);
  }
  @media (max-width: 768px) {
    .hero__title {
      font-size: 32px;
      line-height: 42px;
      white-space: normal;
    }
  }

  .hero__subtitle {
    font-size: var(--text-lg);  /* 18px */
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 auto var(--space-7);  /* 32px 下 */
    max-width: 480px;
  }
  /* 英文版 subtitle 强制单行（与中文"提前掌握额度上限"对等，桌面下不换行） */
  html[data-locale="en"] .hero__subtitle {
    white-space: nowrap;
  }

  .hero__ctas {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);  /* 12px */
    flex-wrap: wrap;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: 12px 28px;
    border-radius: var(--radius-md);  /* 12px */
    font-weight: 500;
    font-size: var(--text-base);  /* 14px */
    transition:
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .hero__cta--primary {
    background: #ffffff;
    color: #000000;
  }
  .hero__cta--primary:hover {
    background: #f0f0f0;
  }

  .hero__cta--ghost {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
  }
  .hero__cta--ghost:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.16);
  }

  /* 打字机：暖橙渐变（vibeisland --accent #d97757 → 深色） */
  .typing-text {
    display: inline-block;
    background: linear-gradient(90deg, var(--accent) 0%, var(--accent-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    vertical-align: baseline;
    min-width: 1ch;
    font-weight: 700;
  }

  /* 字体已通过 unicode-range 自动按字符分流（ASCII→JetBrains Mono / CJK→Maple Mono NL），
   * 这里不再需要 :lang(zh) 覆盖。hero 字号保持 60px，所有字符都用 Mono Sans。 */

  .typing-text::after {
    content: "|";
    display: inline-block;
    margin-left: 2px;
    color: var(--accent);
    -webkit-text-fill-color: var(--accent);
    background: none;
    font-weight: 400;
    animation: typing-cursor 1s steps(1) infinite;
  }

  .hero__tail {
    margin-left: 0.3em;
  }

  @keyframes typing-cursor {
    0%, 50%   { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .typing-text::after {
      animation: none;
      opacity: 0;
    }
  }
</style>

<!-- 打字机动画（locale 切换时按新词重建） -->
<script is:inline>
  (function () {
    var TYPING_SPEED = 90;
    var DELETING_SPEED = 45;
    var PAUSE_AFTER_TYPE = 1400;
    var PAUSE_AFTER_DELETE = 300;

    function pickWords(el, locale) {
      var key = "words-" + (locale || "en");
      var raw = el.getAttribute("data-" + key) || el.getAttribute("data-typewriter") || "";
      return raw.split("|").filter(function (w) { return w.length > 0; });
    }

    function TypeWriter(el, words) {
      this.el = el;
      this.words = words;
      this.wordIdx = 0;
      this.charIdx = 0;
      this.isDeleting = false;
      this.alive = true;
      this.timer = null;
      this.el.textContent = "";
      this.tick = this.tick.bind(this);
      this.tick();
    }
    TypeWriter.prototype.tick = function () {
      if (!this.alive) return;
      var word = this.words[this.wordIdx];
      if (this.isDeleting) {
        this.charIdx--;
      } else {
        this.charIdx++;
      }
      this.el.textContent = word.slice(0, this.charIdx);
      var delay = this.isDeleting ? DELETING_SPEED : TYPING_SPEED;
      if (!this.isDeleting && this.charIdx === word.length) {
        delay = PAUSE_AFTER_TYPE;
        this.isDeleting = true;
      } else if (this.isDeleting && this.charIdx === 0) {
        this.isDeleting = false;
        this.wordIdx = (this.wordIdx + 1) % this.words.length;
        delay = PAUSE_AFTER_DELETE;
      }
      this.timer = setTimeout(this.tick, delay);
    };
    TypeWriter.prototype.destroy = function () {
      this.alive = false;
      if (this.timer) clearTimeout(this.timer);
    };

    function locale() {
      return (document.documentElement.getAttribute("data-locale") || "en");
    }

    function spawn(el) {
      var words = pickWords(el, locale());
      if (!words.length) return;
      if (el._qbTw) {
        el._qbTw.destroy();
      }
      el.textContent = "";
      el._qbTw = new TypeWriter(el, words);
    }

    function init() {
      var els = document.querySelectorAll("[data-typewriter]");
      for (var i = 0; i < els.length; i++) {
        spawn(els[i]);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }

    document.addEventListener("qb:locale-applied", function () {
      var els = document.querySelectorAll("[data-typewriter]");
      for (var i = 0; i < els.length; i++) {
        spawn(els[i]);
      }
    });
  })();
</script>