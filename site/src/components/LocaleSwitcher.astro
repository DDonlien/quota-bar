---
// 语言切换器：点击 → 弹出小菜单 → 选 en/zh → 切 html attribute + 写 localStorage
// 不依赖 React/Vue，纯 inline script 绑事件。
---

<button
  type="button"
  class="locale-switcher flex items-center gap-1 cursor-pointer hover:text-white transition-colors text-sm"
  aria-haspopup="listbox"
  aria-expanded="false"
  aria-label="Language"
>
  <svg
    fill="none"
    height="16"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="2"
    viewBox="0 0 24 24"
    width="16"
  >
    <circle cx="12" cy="12" r="10"></circle>
    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
    <path d="M2 12h20"></path>
  </svg>
  <span data-current-locale-label>EN</span>
  <svg
    class="locale-caret transition-transform"
    fill="none"
    height="12"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="2"
    viewBox="0 0 24 24"
    width="12"
  >
    <path d="m6 9 6 6 6-6"></path>
  </svg>
</button>

<ul
  class="locale-menu hidden absolute right-0 mt-2 min-w-[120px] py-1 rounded-lg
         bg-[#1a1a1d] border border-white/10 backdrop-blur-md shadow-xl z-50"
  role="listbox"
>
  <li>
    <button
      type="button"
      data-locale-pick="en"
      class="locale-option w-full text-left px-4 py-2 text-sm text-gray-300 hover:bg-white/10 hover:text-white flex items-center justify-between"
      role="option"
    >
      <span>English</span>
      <span class="locale-tick text-orange-400 opacity-0">✓</span>
    </button>
  </li>
  <li>
    <button
      type="button"
      data-locale-pick="zh"
      class="locale-option w-full text-left px-4 py-2 text-sm text-gray-300 hover:bg-white/10 hover:text-white flex items-center justify-between"
      role="option"
    >
      <span>中文</span>
      <span class="locale-tick text-orange-400 opacity-0">✓</span>
    </button>
  </li>
</ul>

<script is:inline>
  (function () {
    var buttons = document.querySelectorAll(".locale-switcher");
    buttons.forEach(function (btn) {
      // 容器是 Nav 里的 inline 节点，要让 dropdown 相对它定位
      // 用 inline-block wrap：直接给按钮自身加 relative + 让 menu 用 fixed 定位（更稳）
      var menu = btn.parentElement
        ? btn.parentElement.querySelector(".locale-menu")
        : null;
      if (!menu) return;

      btn.style.position = "relative";

      // 绝对定位改为 fixed，按钮 bbox 算位置（避免被父级 transform / overflow 切断）
      function placeMenu() {
        var r = btn.getBoundingClientRect();
        menu.style.position = "fixed";
        menu.style.top = r.bottom + 8 + "px";
        menu.style.right = window.innerWidth - r.right + "px";
        menu.style.left = "auto";
      }

      btn.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        var open = !menu.classList.contains("hidden");
        if (open) {
          menu.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
        } else {
          placeMenu();
          menu.classList.remove("hidden");
          btn.setAttribute("aria-expanded", "true");
        }
      });

      // 点击外部关闭
      document.addEventListener("click", function (e) {
        if (!menu.contains(e.target) && !btn.contains(e.target)) {
          menu.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
        }
      });

      // Esc 关闭
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
          menu.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
        }
      });
    });

    // 选项点击：写 localStorage + 切 attribute
    document.querySelectorAll("[data-locale-pick]").forEach(function (opt) {
      opt.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        var pick = opt.getAttribute("data-locale-pick");
        if (pick !== "en" && pick !== "zh") return;
        try { localStorage.setItem("qb_locale", pick); } catch (_) {}
        document.documentElement.lang = pick === "zh" ? "zh-CN" : "en";
        document.documentElement.setAttribute("data-locale", pick);
        // 关闭菜单
        var menu = opt.closest(".locale-menu");
        if (menu) menu.classList.add("hidden");
        var btn = menu
          ? menu.parentElement.querySelector(".locale-switcher")
          : null;
        if (btn) btn.setAttribute("aria-expanded", "false");
        document.dispatchEvent(
          new CustomEvent("qb:locale-change", { detail: { locale: pick } })
        );
      });
    });
  })();
</script>
