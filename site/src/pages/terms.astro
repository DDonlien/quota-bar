---
// 服务条款 — 站内独立页面，复用 Layout / Nav / Footer，保持视觉与首页一致。
// 结构和样式跟 privacy.astro 完全一致（同一批 legal__* class），保持两个法律页面视觉统一。
//
// 正文直接用 dictionaries.en 渲染进 HTML，理由和做法跟 privacy.astro 顶部注释一致
// （SSR 直出完整英文正文，data-i18n 属性保留给 Layout.astro 的客户端覆盖用）。
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { dictionaries } from "../i18n/dict";

const en = dictionaries.en;
const SECTIONS = ["s1", "s2", "s3", "s4", "s5", "s6", "s7"];
---

<Layout
  title="Terms of Service — Quota Bar"
  description="Quota Bar 服务条款：开源与官方版本的关系、免责声明、合理使用范围。"
>
  <Nav />
  <main class="site-main">
    <section class="legal section">
      <div class="container-content">
        <a class="legal__back" href="/" data-i18n="terms.back">← Back to home</a>

        <div class="legal__header">
          <h1 class="legal__heading" data-i18n="terms.heading">Terms of Service</h1>
          <p class="legal__updated" data-i18n="terms.updated">Last updated: July 18, 2026</p>
        </div>

        <p class="legal__intro" data-i18n="terms.intro">{en["terms.intro"]}</p>

        {SECTIONS.map((key) => (
          <div class="legal__section">
            <h2 data-i18n={`terms.${key}.title`}>{en[`terms.${key}.title`]}</h2>
            <p data-i18n={`terms.${key}.body1`}>{en[`terms.${key}.body1`]}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .site-main {
    padding-top: 8rem;
    padding-bottom: 6rem;
  }

  .legal__back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: var(--space-7);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .legal__back:hover {
    color: var(--text-primary);
  }

  .legal__header {
    margin-bottom: var(--space-6);
  }

  .legal__heading {
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .legal__updated {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .legal__intro {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 68ch;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--border);
  }

  .legal__section {
    max-width: 68ch;
    margin-bottom: var(--space-7);
  }
  .legal__section h2 {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.005em;
    margin-bottom: var(--space-3);
  }
  .legal__section p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }
  .legal__section p:last-child {
    margin-bottom: 0;
  }
</style>
