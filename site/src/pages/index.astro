---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import ProductPreview from "../components/ProductPreview.astro";
import Features from "../components/Features.astro";
import SupportedServices from "../components/SupportedServices.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";

// GitHub 仓库（用于下载按钮动态取最新 nightly release）
const REPO = "DDonlien/quota-bar";
---

<Layout>
  <Nav />
  <main class="site-main">
    <Hero />
    <ProductPreview />
    <Features />
    <SupportedServices />
    <Pricing />
    <FAQ />
  </main>
  <Footer />
</Layout>

<!--
  下载按钮：客户端动态取最新 nightly release（prerelease，不进 /releases/latest API）。
  v0.14.0：直连 api.github.com 失败（大陆等网络环境不可达）时，自动改走同源 Vercel
  endpoint 兜底——见仓库根目录 api/latest-release.mjs / api/download-latest.mjs。
  两者都失败时保留 build 时 hardcode 的 fallback href 不动。
-->
<script define:vars={{ REPO }}>
  const UPDATE_DOWNLOAD = async () => {
    const links = document.querySelectorAll('a[data-download]');
    if (!links.length) return;

    // 缓存的是"最终应该跳转的下载链接"本身，不是 release 对象——这样兜底路径
    // 和直连路径可以共享同一份缓存逻辑，不需要在读缓存时再判断走的是哪条路。
    const CACHE_KEY = 'qb_latest_download_href';
    const CACHE_TTL = 1000 * 60 * 30; // 30 分钟

    let href = null;
    try {
      const cached = sessionStorage.getItem(CACHE_KEY);
      if (cached) {
        const parsed = JSON.parse(cached);
        if (Date.now() - parsed.t < CACHE_TTL) {
          href = parsed.href;
        }
      }
    } catch (_) { /* ignore */ }

    if (!href) {
      href = (await resolveFromGitHub()) ?? (await resolveFromFallback());
      if (href) {
        try {
          sessionStorage.setItem(CACHE_KEY, JSON.stringify({ t: Date.now(), href }));
        } catch (_) { /* ignore quota */ }
      }
    }

    if (!href) return;
    links.forEach((a) => {
      a.href = href;
    });
  };

  const findDmgURL = (release) => {
    const asset = (release?.assets || []).find(
      (a) => typeof a.name === 'string' && a.name.toLowerCase().endsWith('.dmg')
    );
    return asset?.browser_download_url ?? null;
  };

  const resolveFromGitHub = async () => {
    try {
      // nightly-<sha> 是 prerelease，必须用列表 API + per_page=1
      const res = await fetch(
        `https://api.github.com/repos/${REPO}/releases?per_page=1`,
        { headers: { Accept: 'application/vnd.github+json' } }
      );
      if (!res.ok) return null;
      const arr = await res.json();
      if (!Array.isArray(arr) || arr.length === 0) return null;
      return findDmgURL(arr[0]);
    } catch (_) {
      return null; // 离线 / rate limit / 无法直连 GitHub
    }
  };

  const resolveFromFallback = async () => {
    // GitHub 直连都失败了，返回的下载链接也不用原始 github.com 直链——同一个
    // 不可达原因大概率也会让直链打不开，改成同源流式代理 /api/download-latest。
    try {
      const res = await fetch('/api/latest-release', { headers: { Accept: 'application/json' } });
      if (!res.ok) return null;
      const arr = await res.json();
      if (!Array.isArray(arr) || arr.length === 0) return null;
      return findDmgURL(arr[0]) ? '/api/download-latest' : null;
    } catch (_) {
      return null;
    }
  };

  // 不阻塞首屏渲染
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', UPDATE_DOWNLOAD);
  } else {
    UPDATE_DOWNLOAD();
  }
</script>

<style>
  .site-main {
    /* 给 fixed nav 留出空间：nav 高度约 60px，加点 buffer */
    padding-top: 8rem;     /* 128px */
    padding-bottom: 6rem;  /* 96px */
  }
</style>
