---
import LocaleSwitcher from "./LocaleSwitcher.astro";

const REPO = "DDonlien/quota-bar";
---

<!-- BEGIN: MainHeader -->
<header
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-4 bg-[#0f0f11]/80 backdrop-blur-md border-b border-white/5"
>
  <!-- Logo -->
  <div class="flex items-center gap-2 cursor-pointer" onclick="window.location.href='/'">
    <img
      alt="Quota Bar Logo"
      class="h-6 w-6 object-contain"
      src="https://lh3.googleusercontent.com/aida/AP1WRLsjMgT0WIPX4WswIk0h6ox6KqB2WHuhQdufgeYLGRcxfOiocPInM0DnM7Vsu_toR5Yhv-VXVwVe3hV_vgj618TPP_nVMO-pFB5mRyiWvM18HBLNjcXnxv3opcr49Cnri2PZmLNi1z0J9PTxdGpm50rokBnC8cOYZzO_0TYYedk-YhQgQGTptyvgHqqjuvAbUInXzrNJQVJydxGZr4AELNq0uMxuqWpwNetcV_J5vFeL5WQBCgOGrnSKohDn"
    />
    <span class="font-semibold tracking-wide text-sm uppercase">QUOTA BAR</span>
  </div>
  <!-- Navigation & Actions -->
  <div class="flex items-center gap-6 text-sm text-gray-400">
    <a
      class="hover:text-white transition-colors"
      href={`https://github.com/${REPO}/blob/main/CHANGELOG.md`}
      target="_blank"
      rel="noopener"
    >
      <span data-i18n="nav.changelog">Changelog</span>
    </a>
    <LocaleSwitcher />
    <a
      href={`https://github.com/${REPO}/releases`}
      data-download
      class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors"
    >
      <svg fill="currentColor" height="14" viewBox="0 0 24 24" width="14">
        <path
          d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"
        ></path>
      </svg>
      <span data-i18n="nav.download">Download</span>
    </a>
  </div>
</header>
<!-- END: MainHeader -->
