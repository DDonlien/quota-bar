---
// 9 张 Feature 卡。结构 + 图标 → 数组循环渲染，避免 9 段重复 markup。
const FEATURES: { titleKey: string; descKey: string; icon: string }[] = [
  {
    titleKey: "feature.1.title",
    descKey: "feature.1.desc",
    icon: "layers",
  },
  {
    titleKey: "feature.2.title",
    descKey: "feature.2.desc",
    icon: "monitor",
  },
  {
    titleKey: "feature.3.title",
    descKey: "feature.3.desc",
    icon: "bell",
  },
  {
    titleKey: "feature.4.title",
    descKey: "feature.4.desc",
    icon: "dollar",
  },
  {
    titleKey: "feature.5.title",
    descKey: "feature.5.desc",
    icon: "lock",
  },
  {
    titleKey: "feature.6.title",
    descKey: "feature.6.desc",
    icon: "refresh",
  },
  {
    titleKey: "feature.7.title",
    descKey: "feature.7.desc",
    icon: "moon",
  },
  {
    titleKey: "feature.8.title",
    descKey: "feature.8.desc",
    icon: "target",
  },
  {
    titleKey: "feature.9.title",
    descKey: "feature.9.desc",
    icon: "key",
  },
];
---

<!-- BEGIN: Features Grid -->
<section class="max-w-6xl mx-auto px-4 mb-32">
  <div class="features-grid">
    {FEATURES.map((f) => (
      <article class="feature-card">
        <div class="feature-icon" aria-hidden="true">
          {f.icon === "layers" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
            </svg>
          )}
          {f.icon === "monitor" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <rect height="14" rx="2" ry="2" width="20" x="2" y="3"></rect>
              <line x1="8" x2="16" y1="21" y2="21"></line>
              <line x1="12" x2="12" y1="17" y2="21"></line>
            </svg>
          )}
          {f.icon === "bell" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
            </svg>
          )}
          {f.icon === "dollar" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          )}
          {f.icon === "lock" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <rect height="11" rx="2" ry="2" width="18" x="3" y="11"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          )}
          {f.icon === "refresh" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"></path>
            </svg>
          )}
          {f.icon === "moon" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          )}
          {f.icon === "target" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <circle cx="12" cy="12" r="10"></circle>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          )}
          {f.icon === "key" && (
            <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
              <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
            </svg>
          )}
        </div>
        {/* 标题 + 描述默认渲染英文（SSR fallback），客户端 head 同步脚本按 html lang 替换 */}
        <h3 class="feature-title" data-i18n={f.titleKey}></h3>
        <p class="feature-desc" data-i18n={f.descKey}></p>
      </article>
    ))}
  </div>
</section>
<!-- END: Features Grid -->

<style>
  /* 参考 vibeisland.app 的 9 宫格 features 风格：
   *   暗色 + 1px 浅边框 + 圆角 + 内容居中
   *   hover: translateY + 边框高亮（橙） + 阴影加深 + icon 着色
   */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 40px 32px;
    background: rgba(25, 25, 28, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    transition:
      transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 220ms ease,
      background 220ms ease,
      box-shadow 220ms ease;
    cursor: default;
  }

  .feature-card:hover {
    transform: translateY(-3px);
    background: rgba(30, 30, 34, 0.7);
    border-color: rgba(245, 158, 11, 0.55);
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(245, 158, 11, 0.15);
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    margin-bottom: 20px;
    transition:
      color 220ms ease,
      background 220ms ease,
      border-color 220ms ease;
  }

  .feature-card:hover .feature-icon {
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.12);
    border-color: rgba(245, 158, 11, 0.4);
  }

  .feature-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 10px;
    letter-spacing: 0.01em;
  }

  .feature-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.55);
    max-width: 32ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card,
    .feature-icon {
      transition: none;
    }
    .feature-card:hover {
      transform: none;
    }
  }
</style>
